---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="身份证加水印 · 图片文字水印在线工具 - 备案 / 防盗 / 营业执照 | WizGo"
  description="免费在线给图片加文字水印：身份证、营业执照、合同等证件加'仅供xx使用'防冒用水印；网站备案、版权防盗场景下为图片添加文字保护。支持平铺 / 居中 / 右下角排列，可调颜色、字号、透明度、旋转。浏览器本地处理不上传照片。"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: '图片文字水印',
    alternateName: ['身份证加水印', '证件水印', '备案水印工具', '图片加文字水印'],
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    description: '在图片上添加可见的文字水印，用于身份证防冒用、证件复印件、网站备案、版权防盗等场景。支持平铺、居中、右下角三种排列，纯浏览器本地处理不上传。',
    featureList: [
      '身份证 / 营业执照证件水印',
      '仅供备案 / 仅供开户专用水印',
      '平铺 / 居中 / 右下角排列',
      '颜色、字号、透明度、旋转角度可调',
      '浏览器本地处理，图片不上传',
      '支持 PNG / JPG / WebP',
    ],
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: 'https://wizgo.xyz/text-watermark',
  })} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: '如何给图片（身份证 / 证件）添加文字水印',
    description: '三步给图片添加"仅供xx使用"文字水印，防止证件被冒用',
    totalTime: 'PT1M',
    tool: [{ '@type': 'HowToTool', name: '浏览器（Chrome / Safari / Edge）' }],
    step: [
      { '@type': 'HowToStep', name: '上传图片', text: '点击上传区或直接拖拽图片进来，支持 PNG / JPG / WebP，图片只在本机处理不会上传服务器。' },
      { '@type': 'HowToStep', name: '输入水印文字', text: '例如"仅供 xx 银行房贷办理使用"、"仅供 xxx.com 网站备案使用"等。建议写明具体用途和接收方名称。' },
      { '@type': 'HowToStep', name: '调整样式并下载', text: '选择平铺（防裁剪）、调整颜色字号透明度和旋转角度，点击下载 PNG。' },
    ],
  })} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: '给身份证加水印合法吗？',
        acceptedAnswer: {
          '@type': 'Answer',
          text: '合法，且被广泛推荐。在身份证复印件 / 扫描件上标注"仅供 xx 使用"的文字水印，是防止证件被挪作他用的有效手段，公安部、央行、银保监会等均有过相关提示。',
        },
      },
      {
        '@type': 'Question',
        name: '水印文字应该写什么？',
        acceptedAnswer: {
          '@type': 'Answer',
          text: '建议包含「用途 + 接收方 + 日期」三要素，例如"仅供 xx 银行 2026 年房贷办理使用"。越具体越不容易被滥用。',
        },
      },
      {
        '@type': 'Question',
        name: '水印加在哪里最安全？',
        acceptedAnswer: {
          '@type': 'Answer',
          text: '平铺模式最安全——文字斜向铺满整张图，无法通过裁剪去除；右下角等角落水印容易被直接裁掉。建议身份证等重要证件用平铺+半透明灰。',
        },
      },
      {
        '@type': 'Question',
        name: '图片会被上传到服务器吗？',
        acceptedAnswer: {
          '@type': 'Answer',
          text: '不会。本工具所有处理都在你的浏览器本地完成（Canvas 2D），图片文件和水印文字从不离开你的设备，服务器只提供静态页面。',
        },
      },
      {
        '@type': 'Question',
        name: '水印能被 PS 去掉吗？',
        acceptedAnswer: {
          '@type': 'Answer',
          text: '文字水印本质上是可见的像素改动，专业用户用 PS 可以擦除，但耗时且会留下痕迹。对于普通盗用场景（微信转发、被其他网站复用），文字水印的威慑力已经足够。如果需要抗擦除的"隐形签名"，可以用我们的图片隐藏水印工具。',
        },
      },
      {
        '@type': 'Question',
        name: '水印后的图片保存成 JPG 还是 PNG？',
        acceptedAnswer: {
          '@type': 'Answer',
          text: '本工具导出 PNG（无损，水印边缘最清晰）。如果文件太大，可以用"PNG 压缩"工具进一步减小体积。',
        },
      },
    ],
  })} slot="head" />
  <Header />

  <main class="flex-1 py-12">
    <div class="max-w-[1040px] mx-auto px-6">
      <div class="text-center mb-10">
        <h1 class="text-[40px] leading-[1.1] font-semibold text-[#171717] tracking-[-0.04em] mb-3">图片文字水印</h1>
        <p class="text-[15px] text-[#666666]">在图片上添加"仅供备案使用"等文字水印 · 防盗、溯源 · 本地处理不上传</p>
      </div>

      <div class="grid md:grid-cols-[1fr_300px] gap-6">
        <!-- Left: dropzone + preview -->
        <div class="flex flex-col">
          <span class="block text-xs font-medium text-[#666666] mb-2 uppercase tracking-wide">图片</span>
          <label
            id="tw-dropzone"
            for="tw-file"
            class="flex-1 flex flex-col rounded-lg bg-[#fafafa] cursor-pointer transition-shadow
                   shadow-[0_0_0_1px_rgba(0,0,0,0.08)] hover:shadow-[0_0_0_1px_rgba(0,0,0,0.18)]"
          >
            <input id="tw-file" type="file" accept="image/*" class="sr-only" />
            <div data-zone="empty" class="flex-1 flex flex-col items-center justify-center px-6 py-20 text-center min-h-[380px]">
              <svg class="w-7 h-7 text-[#808080] mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 7.5m0 0L7.5 12M12 7.5v12" />
              </svg>
              <p class="text-sm font-medium text-[#171717]">点击或拖放图片到此处</p>
              <p class="mt-1 text-xs text-[#808080]">PNG · JPG · WebP</p>
            </div>
            <div data-zone="filled" id="tw-result-card" class="hidden p-4">
              <div class="flex items-center justify-center min-h-[320px] max-h-[520px] rounded-md bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)] overflow-hidden">
                <canvas id="tw-result" class="max-h-[500px] max-w-full object-contain"></canvas>
              </div>
              <div class="mt-3 flex items-baseline justify-between gap-3">
                <span id="tw-filename" class="flex-1 truncate text-xs text-[#4d4d4d]"></span>
                <span class="shrink-0 text-xs font-medium text-[#171717] underline underline-offset-2 decoration-[#e5e5e5] hover:decoration-[#171717]">更换图片</span>
              </div>
            </div>
          </label>
        </div>

        <!-- Right: controls -->
        <div class="space-y-5">
          <div>
            <label for="tw-text" class="block text-xs font-medium text-[#666666] mb-2 uppercase tracking-wide">水印文字</label>
            <input
              id="tw-text"
              type="text"
              value="仅供网站备案使用"
              maxlength="60"
              class="w-full h-10 px-3 bg-white rounded-md font-mono text-sm text-[#171717] placeholder:text-[#808080]
                     shadow-[0_0_0_1px_rgba(0,0,0,0.08)] focus:shadow-[0_0_0_1px_#171717] focus:outline-none transition-shadow"
              placeholder="例如：仅供网站备案使用"
            />
          </div>

          <div>
            <div class="flex items-baseline justify-between mb-2">
              <label for="tw-size" class="text-xs font-medium text-[#666666] uppercase tracking-wide">字号</label>
              <span id="tw-size-val" class="text-xs text-[#171717] font-mono">40px</span>
            </div>
            <input id="tw-size" type="range" min="12" max="160" step="1" value="40" class="w-full accent-[#171717]" />
          </div>

          <div>
            <div class="flex items-baseline justify-between mb-2">
              <label class="text-xs font-medium text-[#666666] uppercase tracking-wide">颜色</label>
              <label class="flex items-center gap-2 text-xs text-[#666666]">
                <input id="tw-bold" type="checkbox" class="accent-[#171717]" />
                加粗
              </label>
            </div>
            <div class="flex flex-wrap gap-2 mb-3">
              <button type="button" data-color="#ff0000" class="tw-swatch w-7 h-7 rounded-full shadow-[0_0_0_1px_rgba(0,0,0,0.15)] hover:shadow-[0_0_0_2px_#171717] transition-shadow" style="background:#ff0000" title="备案红"></button>
              <button type="button" data-color="#ffffff" class="tw-swatch w-7 h-7 rounded-full shadow-[0_0_0_1px_rgba(0,0,0,0.15)] hover:shadow-[0_0_0_2px_#171717] transition-shadow" style="background:#ffffff" title="白"></button>
              <button type="button" data-color="#d4d4d4" class="tw-swatch w-7 h-7 rounded-full shadow-[0_0_0_1px_rgba(0,0,0,0.15)] hover:shadow-[0_0_0_2px_#171717] transition-shadow" style="background:#d4d4d4" title="浅灰"></button>
              <button type="button" data-color="#808080" class="tw-swatch w-7 h-7 rounded-full shadow-[0_0_0_1px_rgba(0,0,0,0.15)] hover:shadow-[0_0_0_2px_#171717] transition-shadow" style="background:#808080" title="中灰"></button>
              <button type="button" data-color="#4d4d4d" class="tw-swatch w-7 h-7 rounded-full shadow-[0_0_0_1px_rgba(0,0,0,0.15)] hover:shadow-[0_0_0_2px_#171717] transition-shadow" style="background:#4d4d4d" title="深灰"></button>
              <button type="button" data-color="#171717" class="tw-swatch w-7 h-7 rounded-full shadow-[0_0_0_1px_rgba(0,0,0,0.15)] hover:shadow-[0_0_0_2px_#171717] transition-shadow" style="background:#171717" title="炭灰"></button>
              <button type="button" data-color="#000000" class="tw-swatch w-7 h-7 rounded-full shadow-[0_0_0_1px_rgba(0,0,0,0.15)] hover:shadow-[0_0_0_2px_#171717] transition-shadow" style="background:#000000" title="黑"></button>
            </div>
            <div class="flex items-center gap-3">
              <input
                id="tw-color"
                type="color"
                value="#ff0000"
                class="w-10 h-10 rounded-md cursor-pointer bg-transparent shadow-[0_0_0_1px_rgba(0,0,0,0.08)]"
                style="padding:2px;"
                title="自定义颜色"
              />
              <div class="flex-1">
                <div class="flex items-baseline justify-between mb-1">
                  <span class="text-[11px] text-[#808080]">透明度</span>
                  <span id="tw-opacity-val" class="text-[11px] text-[#171717] font-mono">35%</span>
                </div>
                <input id="tw-opacity" type="range" min="0.05" max="1" step="0.05" value="0.35" class="w-full accent-[#171717]" />
              </div>
            </div>
          </div>

          <div id="tw-rotation-row">
            <div class="flex items-baseline justify-between mb-2">
              <label for="tw-rotation" class="text-xs font-medium text-[#666666] uppercase tracking-wide">旋转角度</label>
              <span id="tw-rotation-val" class="text-xs text-[#171717] font-mono">-30°</span>
            </div>
            <input id="tw-rotation" type="range" min="-90" max="90" step="1" value="-30" class="w-full accent-[#171717]" />
          </div>

          <div id="tw-spacing-row">
            <div class="flex items-baseline justify-between mb-2">
              <label for="tw-spacing" class="text-xs font-medium text-[#666666] uppercase tracking-wide">间距</label>
              <span id="tw-spacing-val" class="text-xs text-[#171717] font-mono">1.0×</span>
            </div>
            <input id="tw-spacing" type="range" min="0.5" max="3" step="0.1" value="1" class="w-full accent-[#171717]" />
          </div>

          <div>
            <label class="block text-xs font-medium text-[#666666] mb-2 uppercase tracking-wide">排列方式</label>
            <div class="grid grid-cols-3 gap-1 p-1 rounded-md bg-[#fafafa] shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
              <button type="button" data-pattern="tile" class="tw-pattern-btn h-8 rounded text-xs font-medium bg-[#171717] text-white">平铺</button>
              <button type="button" data-pattern="single" class="tw-pattern-btn h-8 rounded text-xs font-medium text-[#666666] hover:text-[#171717] transition-colors">单个</button>
              <button type="button" data-pattern="corner" class="tw-pattern-btn h-8 rounded text-xs font-medium text-[#666666] hover:text-[#171717] transition-colors">右下角</button>
            </div>
          </div>

          <div class="flex gap-2 pt-2">
            <button
              id="tw-download"
              type="button"
              class="flex-1 h-10 rounded-md bg-[#171717] text-white text-sm font-medium hover:bg-black transition-colors"
            >下载 PNG</button>
            <button
              id="tw-copy"
              type="button"
              class="flex-1 h-10 rounded-md bg-white text-[#171717] text-sm font-medium
                     shadow-[0_0_0_1px_rgba(0,0,0,0.08)] hover:shadow-[0_0_0_1px_#171717] transition-shadow"
            >复制图片</button>
          </div>
        </div>
      </div>

      <!-- Error message -->
      <div
        id="err"
        class="hidden mt-6 px-4 py-3 rounded-lg text-sm text-[#c92a2a] bg-[#fff5f5] shadow-[0_0_0_1px_rgba(201,42,42,0.15)]"
      ></div>

      <!-- Use-case matrix — keyword-dense, scenario-first for Chinese search -->
      <section class="mt-16 max-w-[760px] mx-auto">
        <h2 class="text-2xl font-semibold text-[#171717] tracking-tight mb-5">常见用途</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <article class="p-5 rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
            <h3 class="text-base font-semibold text-[#171717] mb-2">身份证加水印 · 防冒用</h3>
            <p class="text-[14px] leading-[1.7] text-[#4d4d4d]">办理银行业务、租房、工作入职时经常要提交身份证复印件。加上"仅供 xx 银行 2026 年房贷办理使用"一类的文字水印，可以避免身份证信息被挪作贷款、开卡等其它用途，降低冒名风险。建议用<strong>平铺模式</strong>，透明度 30–50%。</p>
          </article>
          <article class="p-5 rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
            <h3 class="text-base font-semibold text-[#171717] mb-2">营业执照 / 合同 / 证件水印</h3>
            <p class="text-[14px] leading-[1.7] text-[#4d4d4d]">公司营业执照、开户许可证、合同扫描件提交给合作方时，加上"仅供 xx 用途"水印可以限制被复用。同样适用于学位证、驾照、护照等证件的电子副本。</p>
          </article>
          <article class="p-5 rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
            <h3 class="text-base font-semibold text-[#171717] mb-2">网站备案水印</h3>
            <p class="text-[14px] leading-[1.7] text-[#4d4d4d]">ICP 备案材料里，主体身份证件和法人授权书都需要在图片上加水印。常见格式："仅供 xxx.com 网站 ICP 备案使用"，红色平铺是阿里云 / 腾讯云 / 华为云备案推荐样式。</p>
          </article>
          <article class="p-5 rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
            <h3 class="text-base font-semibold text-[#171717] mb-2">防盗图 / 版权保护</h3>
            <p class="text-[14px] leading-[1.7] text-[#4d4d4d]">摄影作品、产品图、插画发布到社交平台前加上作者署名或站点域名，可以显著降低被直接盗用的概率。版权标用<strong>右下角</strong>低调；防盗用<strong>平铺</strong>强覆盖。</p>
          </article>
        </div>
      </section>

      <!-- HowTo -->
      <section class="mt-12 max-w-[760px] mx-auto">
        <h2 class="text-2xl font-semibold text-[#171717] tracking-tight mb-5">使用步骤</h2>
        <ol class="space-y-3 text-[15px] leading-[1.7] text-[#4d4d4d] list-decimal pl-5">
          <li><strong>上传图片</strong>——点击上传区或拖拽图片进来，支持 PNG / JPG / WebP，图片只在本机处理不会上传服务器。</li>
          <li><strong>输入水印文字</strong>——写明具体用途和接收方名称，例如"仅供 xx 银行房贷办理使用"或"仅供 xxx.com 网站 ICP 备案使用"，越具体越难被滥用。</li>
          <li><strong>调整样式</strong>——选择排列方式（平铺最防裁剪）、颜色（备案场景建议红色 / 灰色）、字号、透明度、旋转角度，实时预览结果。</li>
          <li><strong>下载 PNG</strong>——点击下载按钮即可保存到本地，或用"复制图片"直接贴到微信 / 邮件。</li>
        </ol>
      </section>

      <!-- FAQ (also picked up by FAQPage schema above) -->
      <section class="mt-12 max-w-[760px] mx-auto">
        <h2 class="text-2xl font-semibold text-[#171717] tracking-tight mb-5">常见问题</h2>
        <div class="space-y-2">
          <details class="group p-4 rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
            <summary class="cursor-pointer text-[15px] font-medium text-[#171717] list-none flex items-center justify-between">
              给身份证加水印合法吗？
              <span class="text-[#808080] text-xs group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <p class="mt-3 text-[14px] leading-[1.7] text-[#4d4d4d]">合法，且被广泛推荐。在身份证复印件 / 扫描件上标注"仅供 xx 使用"的文字水印，是防止证件被挪作他用的有效手段，公安部、央行、银保监会都有过相关提示。</p>
          </details>
          <details class="group p-4 rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
            <summary class="cursor-pointer text-[15px] font-medium text-[#171717] list-none flex items-center justify-between">
              水印文字应该写什么？
              <span class="text-[#808080] text-xs group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <p class="mt-3 text-[14px] leading-[1.7] text-[#4d4d4d]">建议包含「用途 + 接收方 + 日期」三要素，例如"仅供 xx 银行 2026 年房贷办理使用"。越具体越不容易被滥用。如果是网站备案，写"仅供 yourdomain.com 网站 ICP 备案使用"。</p>
          </details>
          <details class="group p-4 rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
            <summary class="cursor-pointer text-[15px] font-medium text-[#171717] list-none flex items-center justify-between">
              水印加在哪里最安全？
              <span class="text-[#808080] text-xs group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <p class="mt-3 text-[14px] leading-[1.7] text-[#4d4d4d]">平铺模式最安全——文字斜向铺满整张图，无法通过裁剪去除。右下角等角落水印容易被直接裁掉。身份证、银行卡等重要证件建议平铺 + 半透明灰，既安全又不影响识别。</p>
          </details>
          <details class="group p-4 rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
            <summary class="cursor-pointer text-[15px] font-medium text-[#171717] list-none flex items-center justify-between">
              图片会被上传到服务器吗？
              <span class="text-[#808080] text-xs group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <p class="mt-3 text-[14px] leading-[1.7] text-[#4d4d4d]">不会。本工具所有处理都在你的浏览器本地完成（Canvas 2D 直接绘制像素），图片文件和水印文字从不离开你的设备。可以断网后继续使用。</p>
          </details>
          <details class="group p-4 rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
            <summary class="cursor-pointer text-[15px] font-medium text-[#171717] list-none flex items-center justify-between">
              水印能被 PS 去掉吗？
              <span class="text-[#808080] text-xs group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <p class="mt-3 text-[14px] leading-[1.7] text-[#4d4d4d]">文字水印本质上是可见的像素改动，专业用户用 PS 可以擦除，但耗时且会留下痕迹。对于普通盗用场景（微信转发、被其他网站复用），文字水印的威慑力已经足够。如果需要抗擦除的"隐形签名"，可以用我们的<a href="/watermark" class="text-[#0072f5] hover:underline">图片隐藏水印</a>工具。</p>
          </details>
          <details class="group p-4 rounded-lg bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)]">
            <summary class="cursor-pointer text-[15px] font-medium text-[#171717] list-none flex items-center justify-between">
              水印后的图片太大怎么办？
              <span class="text-[#808080] text-xs group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <p class="mt-3 text-[14px] leading-[1.7] text-[#4d4d4d]">本工具导出 PNG（无损，水印边缘最清晰）。如果文件太大影响上传或发送，可以用<a href="/compress-png" class="text-[#0072f5] hover:underline">PNG 压缩</a>进一步减小体积，或用<a href="/png-to-jpg" class="text-[#0072f5] hover:underline">PNG 转 JPG</a>换成更小的格式。</p>
