---
import ConvertPairPage from '../components/pages/ConvertPairPage.astro';
import type { ConvertFormat } from '../i18n/schema';

export const getStaticPaths = () => {
  const formats: ConvertFormat[] = ['png', 'jpg', 'webp', 'gif', 'bmp'];
  const paths: { params: { from: ConvertFormat; to: ConvertFormat } }[] = [];
  for (const from of formats) {
    for (const to of formats) {
      if (from !== to) paths.push({ params: { from, to } });
    }
  }
  return paths;
};

const { from, to } = Astro.params as { from: ConvertFormat; to: ConvertFormat };
const FORMATS: readonly ConvertFormat[] = [
  'png',
  'jpg',
  'webp',
  'gif',
  'bmp',
] as const;
if (!FORMATS.includes(from) || !FORMATS.includes(to)) {
  return Astro.redirect('/convert');
}
---

<ConvertPairPage locale="zh-CN" from={from} to={to} />
