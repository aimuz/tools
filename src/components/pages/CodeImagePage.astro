---
import Layout from '../../layouts/Layout.astro';
import Header from '../layout/Header.astro';
import Footer from '../layout/Footer.astro';
import { useTranslations } from '../../i18n';
import type { Locale } from '../../i18n/config';
import { absoluteUrl } from '../../i18n/seo';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const ci = t.pages.codeImage;
const pageUrl = absoluteUrl(locale, '/code-image');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: ci.schema.name,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  description: ci.schema.description,
  inLanguage: locale,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  url: pageUrl,
};
---

<Layout title={ci.title} description={ci.description} locale={locale}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
    slot="head"
  />
  <Header locale={locale} />

  <main class="flex-1 py-8">
    <div
      class="max-w-[900px] mx-auto px-6"
      data-i18n-render-error={ci.renderError}
    >
      <div class="text-center mb-8">
        <h1 class="text-3xl font-semibold text-[#171717] mb-2">{ci.h1}</h1>
        <p class="text-gray-500">{ci.subheading}</p>
      </div>

      <div class="flex flex-wrap gap-3 mb-6">
        <select
          id="language-select"
          class="px-3 py-2 bg-white border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-[#171717]"
        >
          <option value="javascript">JavaScript</option>
          <option value="typescript">TypeScript</option>
          <option value="python">Python</option>
          <option value="java">Java</option>
          <option value="go">Go</option>
          <option value="rust">Rust</option>
          <option value="css">CSS</option>
          <option value="html">HTML</option>
          <option value="json">JSON</option>
          <option value="sql">SQL</option>
          <option value="bash">Bash</option>
        </select>

        <select
          id="theme-select"
          class="px-3 py-2 bg-white border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-[#171717]"
        >
          <option value="onedark">One Dark</option>
          <option value="dracula">Dracula</option>
          <option value="github">GitHub</option>
        </select>

        <button
          id="format-btn"
          class="px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:border-[#171717] hover:text-[#171717] transition-colors flex items-center gap-2"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
          {ci.formatBtn}
        </button>

        <button
          id="sample-btn"
          class="px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:border-[#171717] hover:text-[#171717] transition-colors"
        >
          {ci.sampleBtn}
        </button>

        <button
          id="copy-btn"
          class="ml-auto px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:border-[#171717] hover:text-[#171717] transition-colors flex items-center gap-2"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
            ></path>
          </svg>
          {ci.copyBtn}
        </button>

        <button
          id="download-btn"
          class="px-4 py-2 bg-[#171717] text-white rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors flex items-center gap-2"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
            ></path>
          </svg>
          {ci.downloadBtn}
        </button>
      </div>

      <div id="editor-container" class="rounded-xl overflow-hidden shadow-2xl">
        <div
          class="flex items-center justify-between px-4 py-3 bg-[#21252b] border-b border-[#3e4451]"
        >
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
          </div>
          <span id="filename" class="text-sm text-[#9da5b4] font-mono"
            >main.js</span
          >
          <div class="w-16"></div>
        </div>

        <div id="editor-body" class="relative bg-[#282c34]">
          <textarea
            id="code-input"
            class="block w-full resize-none focus:outline-none z-20 overflow-hidden bg-transparent relative"
            style="color: transparent; caret-color: #abb2bf; padding: 20px 24px; font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Fira Code', Consolas, monospace; font-size: 14px; line-height: 1.6; white-space: pre; tab-size: 2; min-height: 320px; field-sizing: content;"
            placeholder={ci.placeholder}
            spellcheck="false"
            rows="1"></textarea>

          <pre
            id="highlight-layer"
            class="absolute inset-0 w-full m-0 pointer-events-none overflow-hidden z-10 bg-transparent"
            style="padding: 20px 24px; font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Fira Code', Consolas, monospace; font-size: 14px; line-height: 1.6; white-space: pre; tab-size: 2;">
          </pre>
        </div>
      </div>

      <div class="mt-6 p-4 bg-gray-50 rounded-lg">
        <p class="text-sm text-gray-500">
          <span class="font-medium text-[#171717]">{ci.tipPrefix}</span>
          {ci.tipBody}
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const root = document.querySelector<HTMLElement>('main .max-w-\\[900px\\]')!;
  const D = root.dataset;

  const languages: Record<string, any> = {
    javascript: {
      keywords:
        /\b(const|let|var|function|return|if|else|for|while|class|import|export|from|async|await|new|this|try|catch|throw|typeof|instanceof|in|of)\b/g,
      strings: /(['"`])(?:(?!\1)[^\\]|\\.)*\1/g,
      comments: /\/\/.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_$][a-zA-Z0-9_$]*(?=\()/g,
    },
    typescript: {
      keywords:
        /\b(const|let|var|function|return|if|else|for|while|class|import|export|from|async|await|new|this|try|catch|throw|interface|type|extends|implements|readonly|private|public|protected)\b/g,
      strings: /(['"`])(?:(?!\1)[^\\]|\\.)*\1/g,
      comments: /\/\/.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_$][a-zA-Z0-9_$]*(?=\()/g,
    },
    python: {
      keywords:
        /\b(def|class|return|if|else|elif|for|while|import|from|as|try|except|raise|with|lambda|None|True|False|and|or|not|in|is)\b/g,
      strings: /(['"""'''"])(?:(?!\1)[^\\]|\\.)*\1/g,
      comments: /#.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_][a-zA-Z0-9_]*(?=\()/g,
    },
    java: {
      keywords:
        /\b(public|private|protected|class|interface|extends|implements|return|if|else|for|while|import|package|static|final|void|int|String|boolean|new|this|try|catch)\b/g,
      strings: /"(?:[^"\\]|\\.)*"/g,
      comments: /\/\/.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_$][a-zA-Z0-9_$]*(?=\()/g,
    },
    go: {
      keywords:
        /\b(package|import|func|return|if|else|for|range|var|const|type|struct|interface|map|chan|go|defer|make|new)\b/g,
      strings: /`(?:[^`])*`|"(?:[^"\\]|\\.)*"/g,
      comments: /\/\/.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_][a-zA-Z0-9_]*(?=\()/g,
    },
    rust: {
      keywords:
        /\b(fn|let|mut|const|return|if|else|for|while|match|impl|struct|enum|trait|use|mod|pub|crate|where|loop|async|await)\b/g,
      strings: /"(?:[^"\\]|\\.)*"|b"(?:[^"\\]|\\.)*"/g,
      comments: /\/\/.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_][a-zA-Z0-9_]*(?=\()/g,
      macros: /\b[a-zA-Z_][a-zA-Z0-9_]*!/g,
    },
    css: {
      properties: /[\w-]+(?=\s*:)/g,
      selectors: /[.#][\w-]+/g,
      strings: /"(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'/g,
      comments: /\/\*[\s\S]*?\*\//g,
      numbers: /\b\d+(\.\d+)?(px|em|rem|%|vh|vw|s|ms|deg)?\b/g,
      keywords:
        /\b(color|background|font|margin|padding|border|display|position|width|height|flex|grid|none|auto|absolute|relative|fixed|center)\b/g,
    },
    html: {
      tags: /&lt;\/?[\w-]+/g,
      attrs: /\s[\w-]+(?==)/g,
      strings: /"(?:[^"\\]|\\.)*"/g,
      comments: /&lt;!--[\s\S]*?--&gt;/g,
    },
    json: {
      keys: /"(?:[^"\\]|\\.)*"(?=\s*:)/g,
      strings: /"(?:[^"\\]|\\.)*"/g,
      numbers: /\b\d+(\.\d+)?\b/g,
      booleans: /\b(true|false|null)\b/g,
    },
    sql: {
      keywords:
        /\b(SELECT|INSERT|UPDATE|DELETE|FROM|WHERE|JOIN|LEFT|RIGHT|INNER|OUTER|ON|GROUP|ORDER|BY|HAVING|LIMIT|OFFSET|AND|OR|NOT|NULL|AS|CREATE|TABLE|VALUES|INDEX|PRIMARY|KEY|FOREIGN|REFERENCES)\b/gi,
      strings: /'(?:[^'\\]|\\.)*'/g,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b(COUNT|SUM|AVG|MIN|MAX|DISTINCT)\b/gi,
    },
    bash: {
      keywords:
        /\b(if|then|else|elif|fi|for|while|do|done|case|esac|function|return|exit|echo|export|source|cd|ls|pwd|cat|grep|awk|sed)\b/g,
      strings: /"(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'/g,
      comments: /#.*$/gm,
      variables: /\$\w+|\$\{[^}]*\}/g,
    },
  };

  const themes: Record<string, any> = {
    onedark: {
      bg: '#282c34',
      headerBg: '#21252b',
      border: '#3e4451',
      text: '#abb2bf',
      keyword: '#c678dd',
      string: '#98c379',
      comment: '#5c6370',
      number: '#d19a66',
      function: '#61afef',
      variable: '#e06c75',
      tag: '#e06c75',
      attr: '#d19a66',
      filename: '#9da5b4',
    },
    dracula: {
      bg: '#282a36',
      headerBg: '#21222c',
      border: '#44475a',
      text: '#f8f8f2',
      keyword: '#ff79c6',
      string: '#f1fa8c',
      comment: '#6272a4',
      number: '#bd93f9',
      function: '#50fa7b',
      variable: '#f8f8f2',
      tag: '#ff79c6',
      attr: '#50fa7b',
      filename: '#6272a4',
    },
    github: {
      bg: '#ffffff',
      headerBg: '#f6f8fa',
      border: '#d1d5da',
      text: '#24292e',
      keyword: '#d73a49',
      string: '#032f62',
      comment: '#6a737d',
      number: '#005cc5',
      function: '#6f42c1',
      variable: '#e36209',
      tag: '#22863a',
      attr: '#6f42c1',
      filename: '#586069',
    },
  };

  const fileExtensions: Record<string, string> = {
    javascript: 'js',
    typescript: 'ts',
    python: 'py',
    java: 'java',
    go: 'go',
    rust: 'rs',
    css: 'css',
    html: 'html',
    json: 'json',
    sql: 'sql',
    bash: 'sh',
  };

  const codeInput = document.getElementById(
    'code-input',
  ) as HTMLTextAreaElement | null;
  const highlightLayer = document.getElementById('highlight-layer');
  const filename = document.getElementById('filename');
  const editorContainer = document.getElementById('editor-container');
  const formatBtn = document.getElementById('format-btn');
  const canvas = document.createElement('canvas');
  const languageSelect = document.getElementById(
    'language-select',
  ) as HTMLSelectElement | null;
  const themeSelect = document.getElementById(
    'theme-select',
  ) as HTMLSelectElement | null;
  const downloadBtn = document.getElementById('download-btn');
  const sampleBtn = document.getElementById('sample-btn');

  const samples: Record<string, string> = {
    javascript: `function fibonacci(n) {\n  if (n <= 1) return n;\n  return fibonacci(n - 1) + fibonacci(n - 2);\n}\n\n// Calculate first 10 numbers\nfor (let i = 0; i < 10; i++) {\n  console.log(fibonacci(i));\n}`,
    typescript: `interface User {\n  id: number;\n  name: string;\n  email: string;\n}\n\nasync function getUser(id: number): Promise<User> {\n  const response = await fetch(\`/api/users/\${id}\`);\n  return response.json();\n}`,
    python: `def fibonacci(n):\n    if n <= 1:\n        return n\n    return fibonacci(n-1) + fibonacci(n-2)\n\n# Calculate first 10 numbers\nfor i in range(10):\n    print(fibonacci(i))`,
    java: `public class Fibonacci {\n    public static int fib(int n) {\n        if (n <= 1) return n;\n        return fib(n - 1) + fib(n - 2);\n    }\n\n    public static void main(String[] args) {\n        for (int i = 0; i < 10; i++) {\n            System.out.println(fib(i));\n        }\n    }\n}`,
    go: `package main\n\nimport "fmt"\n\nfunc fibonacci(n int) int {\n    if n <= 1 {\n        return n\n    }\n    return fibonacci(n-1) + fibonacci(n-2)\n}\n\nfunc main() {\n    for i := 0; i < 10; i++ {\n        fmt.Println(fibonacci(i))\n    }\n}`,
    rust: `fn fibonacci(n: u32) -> u32 {\n    match n {\n        0 | 1 => n,\n        _ => fibonacci(n - 1) + fibonacci(n - 2),\n    }\n}\n\nfn main() {\n    for i in 0..10 {\n        println!("{}", fibonacci(i));\n    }\n}`,
    css: `.container {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n}\n\n.card {\n  padding: 2rem;\n  border-radius: 1rem;\n  background: white;\n  box-shadow: 0 20px 40px rgba(0,0,0,0.1);\n}`,
    html: `<!DOCTYPE html>\n<html lang="en">\n<head>\n  <meta charset="UTF-8">\n  <title>Hello World</title>\n</head>\n<body>\n  <div class="container">\n    <h1>Hello, World!</h1>\n    <p>Welcome to my website.</p>\n  </div>\n</body>\n</html>`,
    json: `{\n  "name": "my-project",\n  "version": "1.0.0",\n  "description": "A sample project",\n  "main": "index.js",\n  "scripts": {\n    "start": "node index.js",\n    "test": "jest"\n  },\n  "dependencies": {\n    "express": "^4.18.0"\n  }\n}`,
    sql: `SELECT u.id, u.name, u.email, COUNT(o.id) as order_count\nFROM users u\nLEFT JOIN orders o ON u.id = o.user_id\nWHERE u.created_at >= '2024-01-01'\nGROUP BY u.id\nORDER BY order_count DESC\nLIMIT 10;`,
    bash: `#!/bin/bash\n\n# Backup script\nBACKUP_DIR="/backup/$(date +%Y%m%d)"\nSOURCE_DIR="/data"\n\necho "Starting backup..."\nmkdir -p "$BACKUP_DIR"\ntar -czf "$BACKUP_DIR/archive.tar.gz" "$SOURCE_DIR"\necho "Backup complete: $BACKUP_DIR"`,
  };

  function escapeHtml(text: string) {
    return text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function highlightCode(code: string, language: string, theme: any) {
    const lang = languages[language];
    if (!lang)
      return `<span style="color:${theme.text}">${escapeHtml(code)}</span>`;
    const lines = code.split('\n');
    let html = '';
    lines.forEach((line) => {
      let lineHtml = '';
      let pos = 0;
      const patterns = [
        { regex: lang.comments || null, color: theme.comment },
        { regex: lang.strings || null, color: theme.string },
        { regex: lang.keywords || null, color: theme.keyword },
        { regex: lang.numbers || null, color: theme.number },
        { regex: lang.functions || null, color: theme.function },
        { regex: lang.variables || null, color: theme.variable },
        { regex: lang.tags || null, color: theme.tag },
        { regex: lang.attrs || null, color: theme.attr },
        { regex: lang.selectors || null, color: theme.function },
        { regex: lang.properties || null, color: theme.keyword },
        { regex: lang.booleans || null, color: theme.keyword },
        { regex: lang.macros || null, color: theme.variable },
      ];
      while (pos < line.length) {
        let matched = false;
        for (const { regex, color } of patterns) {
          if (!regex) continue;
          regex.lastIndex = pos;
          const match = regex.exec(line);
          if (match && match.index === pos) {
            lineHtml += `<span style="color:${color}">${escapeHtml(match[0])}</span>`;
            pos += match[0].length;
            matched = true;
            break;
          }
        }
        if (!matched) {
          lineHtml += `<span style="color:${theme.text}">${escapeHtml(line[pos])}</span>`;
          pos++;
        }
      }
      html += lineHtml + '\n';
    });
    return html;
  }

  function applyTheme(theme: any) {
    if (editorContainer) editorContainer.style.backgroundColor = theme.bg;
    const header = editorContainer?.querySelector(
      'div:first-child',
    ) as HTMLElement | null;
    if (header) {
      header.style.backgroundColor = theme.headerBg;
      header.style.borderColor = theme.border;
    }
    const codeArea = codeInput?.parentElement;
    if (codeArea) codeArea.style.backgroundColor = theme.bg;
    if (codeInput) codeInput.style.caretColor = theme.text;
    if (highlightLayer) highlightLayer.style.color = theme.text;
    if (filename) filename.style.color = theme.filename;
  }

  function render() {
    const code = codeInput?.value || '';
    const language = languageSelect?.value || 'javascript';
    const themeName = themeSelect?.value || 'onedark';
    const theme = themes[themeName];
    applyTheme(theme);
    if (highlightLayer)
      highlightLayer.innerHTML = highlightCode(code, language, theme);
    const ext = fileExtensions[language] || 'txt';
    if (filename) filename.textContent = `main.${ext}`;
    syncHeight();
  }

  function syncScroll() {
    if (highlightLayer && codeInput) {
      highlightLayer.scrollTop = codeInput.scrollTop;
      highlightLayer.scrollLeft = codeInput.scrollLeft;
    }
  }

  function syncHeight() {
    if (highlightLayer && codeInput)
      highlightLayer.style.height = codeInput.offsetHeight + 'px';
  }

  function autoResize() {
    if (!codeInput) return;
    codeInput.style.height = 'auto';
    const newHeight = Math.max(320, codeInput.scrollHeight);
    codeInput.style.height = newHeight + 'px';
    syncHeight();
  }

  codeInput?.addEventListener('input', () => {
    autoResize();
    render();
  });
  codeInput?.addEventListener('scroll', syncScroll, { passive: true });
  languageSelect?.addEventListener('change', render);
  themeSelect?.addEventListener('change', render);

  async function formatCode(code: string, language: string) {
    if (!code.trim()) return code;
    if (language === 'sql') {
      try {
        const { format } = await import('sql-formatter');
        return format(code, {
          language: 'sql',
          indent: '  ',
          keywordCase: 'upper',
          linesBetweenQueries: 1,
        });
      } catch (error) {
        console.error('SQL format error:', error);
        return code;
      }
    }
    const supportedLangs = ['javascript', 'typescript', 'json', 'css', 'html'];
    if (!supportedLangs.includes(language)) return code;
    try {
      if (typeof (window as any).prettier === 'undefined') {
        await loadScript('https://unpkg.com/prettier@3.1.1/standalone.js');
      }
      const prettier = (window as any).prettier;
      let parser = 'babel';
      switch (language) {
        case 'javascript':
          parser = 'babel';
          break;
        case 'typescript':
          parser = 'typescript';
          break;
        case 'json':
          parser = 'json';
          break;
        case 'css':
          parser = 'css';
          break;
        case 'html':
          parser = 'html';
          break;
      }
      return prettier.format(code, {
        parser,
        tabWidth: 2,
        useTabs: false,
        semi: true,
        singleQuote: true,
        trailingComma: 'es5',
        printWidth: 80,
        bracketSpacing: true,
        arrowParens: 'avoid',
        endOfLine: 'lf',
      });
    } catch (error) {
      console.error('Prettier format error:', error);
      return code;
    }
  }

  function loadScript(src: string) {
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = src;
      script.onload = resolve;
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  formatBtn?.addEventListener('click', async () => {
    const code = codeInput?.value || '';
    const language = languageSelect?.value || 'javascript';
    if (codeInput && code.trim()) {
      const formatted = await formatCode(code, language);
      codeInput.value = formatted;
      autoResize();
      render();
    }
  });

  sampleBtn?.addEventListener('click', () => {
    const lang = languageSelect?.value || 'javascript';
    if (codeInput) {
      codeInput.value = samples[lang] || '';
      autoResize();
      render();
    }
  });

  async function renderExportCanvas(): Promise<HTMLCanvasElement | null> {
    const code = codeInput?.value || '';
    const language = languageSelect?.value || 'javascript';
    const themeName = themeSelect?.value || 'onedark';
    const theme = themes[themeName];
    const ctx = canvas.getContext('2d');
    if (!ctx) return null;
    const padding = { x: 28, y: 24 };
    const fontSize = 14;
    const lineHeight = 22;
    const headerHeight = 46;
    const buttonRadius = 6;
    const lines = code.split('\n');
    const maxLineLength = Math.max(...lines.map((l) => l.length), 30);
    const contentWidth = Math.max(480, maxLineLength * 9 + padding.x * 2);
    const contentHeight = Math.max(
      200,
      lines.length * lineHeight + padding.y * 2,
    );
    const width = contentWidth;
    const height = headerHeight + contentHeight;
    canvas.width = width * 2;
    canvas.height = height * 2;
    ctx.scale(2, 2);
    ctx.fillStyle = theme.bg;
    ctx.fillRect(0, 0, width, height);
    ctx.fillStyle = theme.headerBg;
    ctx.fillRect(0, 0, width, headerHeight);
    ctx.strokeStyle = theme.border;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, headerHeight);
    ctx.lineTo(width, headerHeight);
    ctx.stroke();
    const buttonY = headerHeight / 2;
    const buttonColors = ['#ff5f57', '#febc2e', '#28c840'];
    buttonColors.forEach((color, i) => {
      ctx.beginPath();
      ctx.arc(20 + i * 20, buttonY, buttonRadius, 0, Math.PI * 2);
      ctx.fillStyle = color;
      ctx.fill();
    });
    ctx.fillStyle = theme.filename;
    ctx.font =
      '13px -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    const ext = fileExtensions[language] || 'txt';
    ctx.fillText(`main.${ext}`, width / 2, buttonY);
    ctx.font = `${fontSize}px "SF Mono", Monaco, "Cascadia Code", "Fira Code", Consolas, monospace`;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'alphabetic';
    const lang = languages[language];
    const codeX = padding.x;
    lines.forEach((line, i) => {
      const y = headerHeight + padding.y + i * lineHeight;
      if (y > height - padding.y) return;
      let x = codeX;
      let pos = 0;
      if (!lang) {
        ctx.fillStyle = theme.text;
        ctx.fillText(line, x, y + fontSize * 0.85);
        return;
      }
      const patterns = [
        { regex: lang.comments || null, color: theme.comment },
        { regex: lang.strings || null, color: theme.string },
        { regex: lang.keywords || null, color: theme.keyword },
        { regex: lang.numbers || null, color: theme.number },
        { regex: lang.functions || null, color: theme.function },
        { regex: lang.variables || null, color: theme.variable },
        { regex: lang.tags || null, color: theme.tag },
        { regex: lang.attrs || null, color: theme.attr },
        { regex: lang.selectors || null, color: theme.function },
        { regex: lang.properties || null, color: theme.keyword },
        { regex: lang.booleans || null, color: theme.keyword },
        { regex: lang.macros || null, color: theme.variable },
      ];
      while (pos < line.length) {
        let matched = false;
        for (const { regex, color } of patterns) {
          if (!regex) continue;
          regex.lastIndex = pos;
          const match = regex.exec(line);
          if (match && match.index === pos) {
            ctx.fillStyle = color;
            ctx.fillText(match[0], x, y + fontSize * 0.85);
            x += ctx.measureText(match[0]).width;
            pos += match[0].length;
            matched = true;
            break;
          }
        }
        if (!matched) {
          ctx.fillStyle = theme.text;
          ctx.fillText(line[pos], x, y + fontSize * 0.85);
          x += ctx.measureText(line[pos]).width;
          pos++;
        }
      }
    });
    return canvas;
  }

  downloadBtn?.addEventListener('click', async () => {
    const c = await renderExportCanvas();
    if (!c) return;
    const link = document.createElement('a');
    link.download = `code-${Date.now()}.png`;
    link.href = c.toDataURL('image/png');
    link.click();
  });

  const copyBtn = document.getElementById(
    'copy-btn',
  ) as HTMLButtonElement | null;
  if (copyBtn) {
    const { bindCopyButton, canvasToPngBlob } =
      await import('../../scripts/clipboard');
    bindCopyButton(copyBtn, () => ({
      blob: (async () => {
        const c = await renderExportCanvas();
        if (!c) throw new Error(D.i18nRenderError ?? 'Render failed');
        return canvasToPngBlob(c);
      })(),
      mime: 'image/png',
    }));
  }

  if (codeInput) codeInput.value = samples.javascript;
  autoResize();
  render();
</script>

