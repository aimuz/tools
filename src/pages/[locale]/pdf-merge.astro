---
import PdfMergePage from '../../components/pages/PdfMergePage.astro';
import { isLocale, type Locale } from '../../i18n/config';

export const getStaticPaths = () => [
  { params: { locale: 'en' } },
  { params: { locale: 'zh-TW' } },
  { params: { locale: 'ja' } },
  { params: { locale: 'ko' } },
  { params: { locale: 'es' } },
  { params: { locale: 'fr' } },
];

const { locale } = Astro.params;
if (!locale || !isLocale(locale)) throw new Error(`Invalid locale: ${locale}`);
---

<PdfMergePage locale={locale as Locale} />
