---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="二维码生成 - 在线文本/链接转二维码工具 | WizGo"
  description="免费在线二维码生成器，支持文本、URL、联系人生成二维码。自定义尺寸、颜色，可下载 PNG/SVG 格式。纯浏览器本地生成不上传。"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: '二维码生成器',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    description: '在线生成二维码，支持自定义尺寸和颜色',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: 'https://wizgo.xyz/qrcode',
  })} slot="head" />
  <Header />

  <main class="flex-1 py-10">
    <div class="max-w-[960px] mx-auto px-6">
      <!-- Title -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-semibold text-[#171717] mb-2">二维码生成</h1>
        <p class="text-gray-500">文本/链接生成二维码 · 自定义样式 · 下载 PNG/SVG · 本地生成不上传</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Settings -->
        <section class="space-y-4">
          <!-- Input -->
          <div class="p-4 bg-white border border-gray-200 rounded-xl">
            <label class="block text-sm font-medium text-[#171717] mb-2">内容</label>
            <textarea
              id="qr-input"
              class="w-full h-24 p-3 bg-gray-50 border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-[#171717] resize-none"
              placeholder="输入文本或网址..."
            ></textarea>
            <p class="text-xs text-gray-400 mt-2">支持：文本、网址、邮箱、电话号码等</p>
          </div>

          <!-- Size -->
          <div class="p-4 bg-white border border-gray-200 rounded-xl">
            <label class="block text-sm font-medium text-[#171717] mb-2">尺寸</label>
            <div class="flex flex-wrap gap-2">
              <button data-size="128" class="size-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">128px</button>
              <button data-size="256" class="size-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 bg-[#171717] text-white">256px</button>
              <button data-size="512" class="size-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">512px</button>
              <button data-size="1024" class="size-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">1024px</button>
            </div>
          </div>

          <!-- Colors -->
          <div class="p-4 bg-white border border-gray-200 rounded-xl">
            <label class="block text-sm font-medium text-[#171717] mb-2">颜色</label>
            <div class="flex gap-4">
              <div class="flex items-center gap-2">
                <input type="color" id="color-dark" value="#000000" class="w-10 h-10 rounded-lg cursor-pointer border-0 p-0" />
                <span class="text-xs text-gray-500">前景色</span>
              </div>
              <div class="flex items-center gap-2">
                <input type="color" id="color-light" value="#FFFFFF" class="w-10 h-10 rounded-lg cursor-pointer border-0 p-0" />
                <span class="text-xs text-gray-500">背景色</span>
              </div>
            </div>
          </div>

          <!-- Error Correction -->
          <div class="p-4 bg-white border border-gray-200 rounded-xl">
            <label class="block text-sm font-medium text-[#171717] mb-2">容错级别</label>
            <div class="flex flex-wrap gap-2">
              <button data-level="L" class="level-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]" title="低 - 约 7% 容错">低</button>
              <button data-level="M" class="level-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 bg-[#171717] text-white" title="中 - 约 15% 容错">中</button>
              <button data-level="Q" class="level-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]" title="高 - 约 25% 容错">高</button>
              <button data-level="H" class="level-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]" title="最高 - 约 30% 容错">最高</button>
            </div>
            <p class="text-xs text-gray-400 mt-2">容错级别越高，二维码可被遮挡/损坏的部分越多</p>
          </div>

          <!-- Actions -->
          <div class="flex gap-3">
            <button id="generate-btn" class="flex-1 px-4 py-2 bg-[#171717] text-white text-sm rounded-lg hover:bg-gray-800 transition-colors">
              生成二维码
            </button>
            <button id="reset-btn" class="px-4 py-2 border border-gray-200 text-gray-600 text-sm rounded-lg hover:border-[#171717] transition-colors">
              重置
            </button>
          </div>
        </section>

        <!-- Preview -->
        <section>
          <div class="p-6 bg-white border border-gray-200 rounded-xl min-h-[400px] flex flex-col">
            <div class="flex justify-between items-center mb-4">
              <span class="text-sm font-medium text-[#171717]">预览</span>
              <div class="flex gap-2">
                <button id="download-png" class="text-xs text-gray-400 hover:text-[#171717]" disabled>下载 PNG</button>
                <button id="download-svg" class="text-xs text-gray-400 hover:text-[#171717]" disabled>下载 SVG</button>
              </div>
            </div>

            <!-- QR Container -->
            <div id="qr-container" class="flex-1 flex items-center justify-center bg-gray-50 rounded-lg">
              <p class="text-gray-400 text-sm">输入内容并点击"生成二维码"</p>
            </div>

            <p id="qr-info" class="text-xs text-gray-400 mt-3 text-center"></p>
          </div>
        </section>
      </div>

      <!-- Examples -->
      <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-xl">
        <h3 class="text-sm font-medium text-[#171717] mb-2">使用示例</h3>
        <div class="grid sm:grid-cols-2 gap-3 text-xs text-gray-500">
          <div>
            <span class="font-medium">网址：</span>
            <code class="bg-white px-2 py-1 rounded">https://wizgo.xyz</code>
          </div>
          <div>
            <span class="font-medium">邮箱：</span>
            <code class="bg-white px-2 py-1 rounded">mailto:hello@example.com</code>
          </div>
          <div>
            <span class="font-medium">电话：</span>
            <code class="bg-white px-2 py-1 rounded">tel:+8612345678900</code>
          </div>
          <div>
            <span class="font-medium">WiFi：</span>
            <code class="bg-white px-2 py-1 rounded">WIFI:T:WPA;S:网络名;P:密码;;</code>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // @ts-ignore
  import QRCode from 'qrcode';

  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

  // Elements
  const qrInput = $<HTMLTextAreaElement>('qr-input');
  const qrContainer = $('qr-container');
  const qrInfo = $('qr-info');
  const generateBtn = $('generate-btn');
  const resetBtn = $('reset-btn');
  const downloadPng = $('download-png');
  const downloadSvg = $('download-svg');
  const colorDark = $<HTMLInputElement>('color-dark');
  const colorLight = $<HTMLInputElement>('color-light');

  let currentSize = 256;
  let currentLevel: 'L' | 'M' | 'Q' | 'H' = 'M';
  let currentDataUrl = '';
  let currentSvg = '';

  // Size selection
  const sizeBtns = document.querySelectorAll<HTMLButtonElement>('.size-btn');
  sizeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentSize = parseInt(btn.dataset.size!);
      sizeBtns.forEach(b => {
        const active = b === btn;
        b.classList.toggle('bg-[#171717]', active);
        b.classList.toggle('text-white', active);
        b.classList.toggle('text-gray-600', !active);
      });
    });
  });

  // Error level selection
  const levelBtns = document.querySelectorAll<HTMLButtonElement>('.level-btn');
  levelBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentLevel = btn.dataset.level as 'L' | 'M' | 'Q' | 'H';
      levelBtns.forEach(b => {
        const active = b === btn;
        b.classList.toggle('bg-[#171717]', active);
        b.classList.toggle('text-white', active);
        b.classList.toggle('text-gray-600', !active);
      });
    });
  });

  // Generate QR Code
  const generateQR = async () => {
    const text = qrInput.value.trim();
    if (!text) {
      qrContainer.innerHTML = '<p class="text-gray-400 text-sm">请输入内容</p>';
      qrInfo.textContent = '';
      downloadPng.disabled = true;
      downloadSvg.disabled = true;
      return;
    }

    qrContainer.innerHTML = '<p class="text-gray-400 text-sm">生成中...</p>';

    try {
      const opts = {
        width: currentSize,
        margin: 2,
        color: {
          dark: colorDark.value,
          light: colorLight.value,
        },
        errorCorrectionLevel: currentLevel,
      };

      // Generate data URL
      currentDataUrl = await QRCode.toDataURL(text, opts);

      // Generate SVG
      currentSvg = await QRCode.toString(text, {
        ...opts,
        type: 'svg',
      });

      // Display
      const img = document.createElement('img');
      img.src = currentDataUrl;
      img.alt = 'QR Code';
      img.className = 'max-w-full max-h-full';
      qrContainer.innerHTML = '';
      qrContainer.appendChild(img);

      // Info
      const chars = text.length;
      const bytes = new TextEncoder().encode(text).length;
      qrInfo.textContent = `内容长度：${chars} 字符 / ${bytes} 字节 · 尺寸：${currentSize}x${currentSize}px`;

      // Enable downloads
      downloadPng.disabled = false;
      downloadSvg.disabled = false;
    } catch (err) {
      qrContainer.innerHTML = '<p class="text-red-500 text-sm">生成失败，请检查内容</p>';
      qrInfo.textContent = '';
      downloadPng.disabled = true;
      downloadSvg.disabled = true;
    }
  };

  // Reset
  const reset = () => {
    qrInput.value = '';
    qrContainer.innerHTML = '<p class="text-gray-400 text-sm">输入内容并点击"生成二维码"</p>';
    qrInfo.textContent = '';
    currentDataUrl = '';
    currentSvg = '';
    downloadPng.disabled = true;
    downloadSvg.disabled = true;

    // Reset settings
    currentSize = 256;
    currentLevel = 'M';
    colorDark.value = '#000000';
    colorLight.value = '#FFFFFF';

    sizeBtns.forEach(b => {
      const active = b.dataset.size === '256';
      b.classList.toggle('bg-[#171717]', active);
      b.classList.toggle('text-white', active);
      b.classList.toggle('text-gray-600', !active);
    });

    levelBtns.forEach(b => {
      const active = b.dataset.level === 'M';
      b.classList.toggle('bg-[#171717]', active);
      b.classList.toggle('text-white', active);
      b.classList.toggle('text-gray-600', !active);
    });
  };

  // Download PNG
  downloadPng.addEventListener('click', () => {
    if (!currentDataUrl) return;
    const a = document.createElement('a');
    a.href = currentDataUrl;
    a.download = `qrcode-${Date.now()}.png`;
    a.click();
  });

  // Download SVG
  downloadSvg.addEventListener('click', () => {
    if (!currentSvg) return;
    const blob = new Blob([currentSvg], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `qrcode-${Date.now()}.svg`;
    a.click();
    URL.revokeObjectURL(url);
  });

  // Event listeners
  generateBtn.addEventListener('click', generateQR);
  resetBtn.addEventListener('click', reset);

  // Auto-generate on input (debounced)
  let debounceTimer: number;
  qrInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = window.setTimeout(() => {
      if (qrInput.value.trim()) {
        generateQR();
      }
    }, 500);
  });

  // Color changes
  colorDark.addEventListener('change', () => {
    if (qrInput.value.trim()) generateQR();
  });
  colorLight.addEventListener('change', () => {
    if (qrInput.value.trim()) generateQR();
  });
</script>
