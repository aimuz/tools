---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="图片隐藏水印 - 嵌入 / 提取隐写文本 | WizGo"
  description="免费在线图片隐藏水印工具。在图片像素里嵌入隐藏文字或从图片提取水印，支持 LSB 和 DCT 两种算法，LSB 容量大、DCT 可经受 JPG 重压。纯浏览器本地处理不上传。"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: '图片隐藏水印',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    description: '在图片像素里嵌入隐藏文字或从图片提取水印，支持 LSB 和 DCT 两种算法，纯浏览器本地处理',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: 'https://wizgo.xyz/watermark',
  })} slot="head" />
  <Header />

  <main class="flex-1 py-12">
    <div class="max-w-[1040px] mx-auto px-6">
      <div class="text-center mb-10">
        <h1 class="text-[40px] leading-[1.1] font-semibold text-[#171717] tracking-[-0.04em] mb-3">图片隐藏水印</h1>
        <p class="text-[15px] text-[#666666]">把文字隐藏进图片像素，或从图片中提取 · 本地处理不上传</p>
      </div>

      <!-- Tabs -->
      <div class="flex gap-1 mb-8 shadow-[inset_0_-1px_0_rgba(0,0,0,0.08)]">
        <button type="button" data-tab="embed" class="tab-btn px-4 py-2.5 text-sm font-medium text-[#171717] shadow-[inset_0_-2px_0_#171717]">嵌入水印</button>
        <button type="button" data-tab="extract" class="tab-btn px-4 py-2.5 text-sm font-medium text-[#666666] hover:text-[#171717] transition-colors">提取水印</button>
      </div>

      <!-- Embed panel -->
      <section data-panel="embed" class="grid md:grid-cols-2 gap-6">
        <!-- Left: upload -->
        <div class="flex flex-col">
          <span class="block text-xs font-medium text-[#666666] mb-2 uppercase tracking-wide">图片</span>
          <label
            id="embed-dropzone"
            for="embed-file"
            class="flex-1 flex flex-col rounded-lg bg-[#fafafa] cursor-pointer transition-shadow
                   shadow-[0_0_0_1px_rgba(0,0,0,0.08)] hover:shadow-[0_0_0_1px_rgba(0,0,0,0.18)]"
          >
            <input id="embed-file" type="file" accept="image/*" class="sr-only" />
            <!-- Empty state -->
            <div data-zone="empty" class="flex-1 flex flex-col items-center justify-center px-6 py-14 text-center min-h-[240px]">
              <svg class="w-7 h-7 text-[#808080] mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 7.5m0 0L7.5 12M12 7.5v12" />
              </svg>
              <p class="text-sm font-medium text-[#171717]">点击或拖放图片到此处</p>
              <p class="mt-1 text-xs text-[#808080]">PNG · JPG · WebP</p>
            </div>
            <!-- Filled state -->
            <div data-zone="filled" class="hidden p-4">
              <div class="flex items-center justify-center h-[260px] rounded-md bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)] overflow-hidden">
                <canvas id="embed-preview" class="max-h-full max-w-full object-contain"></canvas>
              </div>
              <div class="mt-3 flex items-baseline justify-between gap-3">
                <span id="embed-filename" class="flex-1 truncate text-xs text-[#4d4d4d]"></span>
                <span class="shrink-0 text-xs font-medium text-[#171717] underline underline-offset-2 decoration-[#e5e5e5] hover:decoration-[#171717]">更换图片</span>
              </div>
              <p id="embed-capacity" class="mt-2 text-[11px] text-[#808080]"></p>
              <p id="embed-jpg-warn" class="mt-1 text-[11px] text-[#808080] hidden">输出始终为 PNG，以 PNG 保存可保留最大兼容性</p>
            </div>
          </label>
        </div>

        <!-- Right: text + action -->
        <div class="flex flex-col">
          <label for="embed-text" class="block text-xs font-medium text-[#666666] mb-2 uppercase tracking-wide">隐藏文本</label>
          <textarea
            id="embed-text"
            class="flex-1 min-h-[200px] p-3 bg-white rounded-lg font-mono text-sm text-[#171717] placeholder:text-[#808080]
                   shadow-[0_0_0_1px_rgba(0,0,0,0.08)] focus:shadow-[0_0_0_1px_#171717] focus:outline-none
                   resize-none transition-shadow"
            placeholder="例如：© 作者 2026"
          ></textarea>
          <button
            id="embed-run"
            type="button"
            class="mt-3 h-10 rounded-md bg-[#171717] text-white text-sm font-medium
                   hover:bg-black transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >嵌入水印</button>
        </div>

        <!-- Result (full width, shown after embed) -->
        <div id="embed-result" class="md:col-span-2 hidden">
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-medium text-[#666666] uppercase tracking-wide">带水印的结果</span>
            <div class="flex gap-2">
              <a
                id="embed-download"
                class="h-9 inline-flex items-center px-4 rounded-md bg-[#171717] text-white text-sm font-medium
                       hover:bg-black transition-colors"
                download="watermark.png"
                href="#"
              >下载 PNG</a>
              <button
                id="embed-copy"
                type="button"
                class="h-9 px-4 rounded-md bg-white text-[#171717] text-sm font-medium
                       shadow-[0_0_0_1px_rgba(0,0,0,0.08)] hover:shadow-[0_0_0_1px_#171717] transition-shadow"
              >复制图片</button>
            </div>
          </div>
          <div class="flex items-center justify-center h-[320px] rounded-lg bg-[#fafafa] shadow-[0_0_0_1px_rgba(0,0,0,0.08)] overflow-hidden">
            <canvas id="embed-out" class="max-h-full max-w-full object-contain"></canvas>
          </div>
        </div>
      </section>

      <!-- Extract panel -->
      <section data-panel="extract" class="grid md:grid-cols-2 gap-6 hidden">
        <!-- Left: upload (same pattern) -->
        <div class="flex flex-col">
          <span class="block text-xs font-medium text-[#666666] mb-2 uppercase tracking-wide">图片</span>
          <label
            id="extract-dropzone"
            for="extract-file"
            class="flex-1 flex flex-col rounded-lg bg-[#fafafa] cursor-pointer transition-shadow
                   shadow-[0_0_0_1px_rgba(0,0,0,0.08)] hover:shadow-[0_0_0_1px_rgba(0,0,0,0.18)]"
          >
            <input id="extract-file" type="file" accept="image/*" class="sr-only" />
            <div data-zone="empty" class="flex-1 flex flex-col items-center justify-center px-6 py-14 text-center min-h-[240px]">
              <svg class="w-7 h-7 text-[#808080] mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 7.5m0 0L7.5 12M12 7.5v12" />
              </svg>
              <p class="text-sm font-medium text-[#171717]">点击或拖放图片到此处</p>
              <p class="mt-1 text-xs text-[#808080]">PNG · JPG · WebP</p>
            </div>
            <div data-zone="filled" class="hidden p-4">
              <div class="flex items-center justify-center h-[260px] rounded-md bg-white shadow-[0_0_0_1px_rgba(0,0,0,0.08)] overflow-hidden">
                <canvas id="extract-preview" class="max-h-full max-w-full object-contain"></canvas>
              </div>
              <div class="mt-3 flex items-baseline justify-between gap-3">
                <span id="extract-filename" class="flex-1 truncate text-xs text-[#4d4d4d]"></span>
                <span class="shrink-0 text-xs font-medium text-[#171717] underline underline-offset-2 decoration-[#e5e5e5] hover:decoration-[#171717]">更换图片</span>
              </div>
            </div>
          </label>
        </div>

        <!-- Right: result + action (button at bottom) -->
        <div class="flex flex-col">
          <label class="block text-xs font-medium text-[#666666] mb-2 uppercase tracking-wide">提取结果</label>
          <div class="relative flex-1 flex">
            <textarea
              id="extract-text"
              readonly
              class="flex-1 min-h-[200px] p-3 pr-16 bg-white rounded-lg font-mono text-sm text-[#171717] placeholder:text-[#808080]
                     shadow-[0_0_0_1px_rgba(0,0,0,0.08)] resize-none focus:outline-none"
              placeholder="点击下方按钮提取水印"
            ></textarea>
            <button
              id="extract-copy"
              type="button"
              class="absolute top-2 right-2 px-2 py-1 rounded-md text-xs text-[#666666] hover:text-[#171717] hover:bg-[#fafafa] transition-colors"
            >复制</button>
          </div>
          <button
            id="extract-run"
            type="button"
            class="mt-3 h-10 rounded-md bg-[#171717] text-white text-sm font-medium
                   hover:bg-black transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >提取水印</button>
        </div>
      </section>

      <!-- Error message -->
      <div
        id="err"
        class="hidden mt-6 px-4 py-3 rounded-lg text-sm text-[#c92a2a] bg-[#fff5f5] shadow-[0_0_0_1px_rgba(201,42,42,0.15)]"
      ></div>

      <!-- FAQ / SEO body -->
      <section class="mt-16 max-w-[720px] mx-auto">
        <h2 class="text-xl font-semibold text-[#171717] tracking-tight mb-4">工具说明</h2>
        <div class="space-y-3 text-[15px] leading-[1.7] text-[#4d4d4d]">
          <p>把一段文字"藏"进图片里：写入的变化人眼看不出来，图片也不改变尺寸，但用本工具可以把这段文字再读出来。可以用来给图片打隐形签名、溯源或附加说明。</p>
          <p>嵌入结果始终保存为 PNG，以保留全部水印信号。若图片之后被保存成 JPG 再重压缩，短文本通常仍可提取；长文本或多次压缩后可能失效——想更稳妥就保留 PNG 原件。</p>
          <p>所有处理在浏览器本地完成，图片和文本都不会上传。</p>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { initWatermarkPage } from '../scripts/watermark';
  initWatermarkPage();
</script>
