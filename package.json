{
  "name": "wizgo",
  "type": "module",
  "version": "1.0.0",
  "description": "安全快速的本地文件格式转换工具 - wizgo.xyz",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build": "bun run build:wasm && astro build",
    "build:web": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "bun run build && wrangler deploy",
    "format": "prettier --write . && cd rust-wasm && cargo fmt",
    "format:check": "prettier --check . && cd rust-wasm && cargo fmt --check",
    "check:i18n": "bun scripts/check-i18n-placeholders.ts"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/geist-mono": "^5.0.3",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.9",
    "pdf-lib": "^1.17.0",
    "prettier": "^3.8.3",
    "qrcode": "^1.5.4",
    "sql-formatter": "^15.7.3",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@vite-pwa/astro": "^0.4.0",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.3.0",
    "wrangler": "^4.83.0"
  }
}
