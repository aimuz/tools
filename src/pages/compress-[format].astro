---
import CompressFormatPage from '../components/pages/CompressFormatPage.astro';
import type { CompressFormat } from '../i18n/schema';

export const getStaticPaths = () => {
  const formats: CompressFormat[] = ['png', 'jpg', 'webp'];
  return formats.map((format) => ({ params: { format } }));
};

const { format } = Astro.params as { format: CompressFormat };
if (!['png', 'jpg', 'webp'].includes(format)) {
  return Astro.redirect('/compress');
}
---

<CompressFormatPage locale="zh-CN" format={format} />
