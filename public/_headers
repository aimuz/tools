# Global security defaults — applied to every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
  X-Frame-Options: SAMEORIGIN

# Astro hashed build artefacts are content-addressed — safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Rust WASM module served from /rust-image/* is hash-invariant within a release.
/rust-image/*
  Cache-Control: public, max-age=31536000, immutable

# Fallback long-cache for any raw .woff2 (fonts are normally bundled into /_astro/).
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

/sitemap-index.xml
  Cache-Control: public, max-age=3600

/sitemap-0.xml
  Cache-Control: public, max-age=3600

# Service worker must revalidate so new releases propagate.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/workbox-*.js
  Cache-Control: public, max-age=31536000, immutable
