---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="JWT 在线解码/生成/验签工具 - HS256 RS256 ES256 | WizGo"
  description="在线 JSON Web Token 工具，解码 header/payload、验证签名、生成新 token。支持 HS256/384/512、RS256/384/512、ES256/384 算法，浏览器本地运算不上传。"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'JWT 解码/生成/验签',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    description: 'JSON Web Token 在线工具，支持 HS/RS/ES 系列算法，本地运算',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: 'https://wizgo.xyz/jwt',
  })} slot="head" />
  <Header />

  <main class="flex-1 py-10">
    <div class="max-w-[1040px] mx-auto px-6">
      <!-- Title -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-semibold text-[#171717] mb-2">JWT 解码/生成/验签</h1>
        <p class="text-gray-500">JSON Web Token 在线工具 · HS256 RS256 ES256 · 本地运算不上传</p>
      </div>

      <!-- Algorithm selector -->
      <div class="mb-6">
        <p class="text-sm text-gray-500 mb-2">签名算法</p>
        <div id="algo-row" class="flex flex-wrap gap-2">
          <button data-algo="HS256" class="algo-btn px-4 py-2 text-sm rounded-full border border-gray-200 bg-[#171717] text-white">HS256</button>
          <button data-algo="HS384" class="algo-btn px-4 py-2 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">HS384</button>
          <button data-algo="HS512" class="algo-btn px-4 py-2 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">HS512</button>
          <button data-algo="RS256" class="algo-btn px-4 py-2 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">RS256</button>
          <button data-algo="RS384" class="algo-btn px-4 py-2 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">RS384</button>
          <button data-algo="RS512" class="algo-btn px-4 py-2 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">RS512</button>
          <button data-algo="ES256" class="algo-btn px-4 py-2 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">ES256</button>
          <button data-algo="ES384" class="algo-btn px-4 py-2 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">ES384</button>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Encoded -->
        <section>
          <div class="flex justify-between items-center mb-2">
            <span class="text-sm text-gray-500">Encoded · 完整 Token</span>
            <div class="flex gap-2">
              <button id="sample-btn" class="text-sm text-gray-400 hover:text-[#171717]">加载示例</button>
              <button id="copy-btn" class="text-sm text-gray-400 hover:text-[#171717]">复制</button>
            </div>
          </div>
          <textarea
            id="encoded"
            class="w-full h-[440px] p-4 bg-white border border-gray-200 rounded-lg font-mono text-sm leading-relaxed focus:outline-none focus:border-[#171717] resize-none break-all"
            spellcheck="false"
            placeholder="header.payload.signature"
          ></textarea>

          <!-- Verification status -->
          <div id="verify-status" class="mt-3 px-4 py-2 rounded-lg text-sm border border-gray-200 text-gray-500 bg-gray-50">
            <span id="verify-text">输入 token 和密钥以验证签名</span>
          </div>
        </section>

        <!-- Decoded -->
        <section class="space-y-4">
          <div>
            <span class="text-sm text-gray-500">Header</span>
            <textarea
              id="header-json"
              class="mt-2 w-full h-24 p-3 bg-white border border-gray-200 rounded-lg font-mono text-sm focus:outline-none focus:border-[#171717] resize-none"
              spellcheck="false"
            ></textarea>
          </div>

          <div>
            <span class="text-sm text-gray-500">Payload</span>
            <textarea
              id="payload-json"
              class="mt-2 w-full h-40 p-3 bg-white border border-gray-200 rounded-lg font-mono text-sm focus:outline-none focus:border-[#171717] resize-none"
              spellcheck="false"
            ></textarea>
          </div>

          <!-- Symmetric secret -->
          <div id="secret-box">
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-500">Secret（UTF-8 或 base64）</span>
              <label class="text-xs text-gray-400 flex items-center gap-1">
                <input id="secret-base64" type="checkbox" class="accent-[#171717]" />
                secret 是 base64 编码
              </label>
            </div>
            <textarea
              id="secret"
              class="mt-2 w-full h-20 p-3 bg-white border border-gray-200 rounded-lg font-mono text-sm focus:outline-none focus:border-[#171717] resize-none"
              spellcheck="false"
              placeholder="your-256-bit-secret"
            ></textarea>
          </div>

          <!-- Asymmetric keys -->
          <div id="asym-box" class="hidden space-y-3">
            <div>
              <span class="text-sm text-gray-500">Public Key（PEM，用于验签）</span>
              <textarea
                id="pubkey"
                class="mt-2 w-full h-24 p-3 bg-white border border-gray-200 rounded-lg font-mono text-xs focus:outline-none focus:border-[#171717] resize-none"
                spellcheck="false"
                placeholder="-----BEGIN PUBLIC KEY-----&#10;...&#10;-----END PUBLIC KEY-----"
              ></textarea>
            </div>
            <div>
              <span class="text-sm text-gray-500">Private Key（PEM，用于签发）</span>
              <textarea
                id="privkey"
                class="mt-2 w-full h-24 p-3 bg-white border border-gray-200 rounded-lg font-mono text-xs focus:outline-none focus:border-[#171717] resize-none"
                spellcheck="false"
                placeholder="-----BEGIN PRIVATE KEY-----&#10;...&#10;-----END PRIVATE KEY-----"
              ></textarea>
            </div>
          </div>
        </section>
      </div>

      <!-- Error -->
      <div id="err" class="hidden mt-5 p-3 bg-red-50 border border-red-100 rounded-lg text-red-500 text-sm"></div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // ---- DOM ----
  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;
  const encoded = $<HTMLTextAreaElement>('encoded');
  const headerEl = $<HTMLTextAreaElement>('header-json');
  const payloadEl = $<HTMLTextAreaElement>('payload-json');
  const secretEl = $<HTMLTextAreaElement>('secret');
  const secretB64 = $<HTMLInputElement>('secret-base64');
  const pubkeyEl = $<HTMLTextAreaElement>('pubkey');
  const privkeyEl = $<HTMLTextAreaElement>('privkey');
  const secretBox = $('secret-box');
  const asymBox = $('asym-box');
  const verifyBox = $('verify-status');
  const verifyText = $('verify-text');
  const errBox = $('err');
  const sampleBtn = $('sample-btn');
  const copyBtn = $('copy-btn');
  const algoBtns = document.querySelectorAll<HTMLButtonElement>('.algo-btn');

  type Algo = 'HS256' | 'HS384' | 'HS512' | 'RS256' | 'RS384' | 'RS512' | 'ES256' | 'ES384';
  let algo: Algo = 'HS256';
  let updatingFromEncoded = false;
  let updatingFromDecoded = false;

  // ---- base64url helpers ----
  const b64urlEncodeBytes = (bytes: Uint8Array) => {
    let s = '';
    for (let i = 0; i < bytes.length; i++) s += String.fromCharCode(bytes[i]);
    return btoa(s).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
  };
  const b64urlEncodeString = (s: string) => b64urlEncodeBytes(new TextEncoder().encode(s));
  const b64urlDecodeBytes = (s: string) => {
    const pad = s.length % 4 === 2 ? '==' : s.length % 4 === 3 ? '=' : '';
    const b64 = s.replace(/-/g, '+').replace(/_/g, '/') + pad;
    const bin = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return bytes;
  };
  const b64urlDecodeString = (s: string) => new TextDecoder().decode(b64urlDecodeBytes(s));

  // PEM -> DER bytes
  const pemToDer = (pem: string) => {
    const body = pem.replace(/-----BEGIN [^-]+-----/g, '').replace(/-----END [^-]+-----/g, '').replace(/\s+/g, '');
    if (!body) throw new Error('PEM 内容为空');
    const bin = atob(body);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return bytes;
  };

  const hashFromAlgo = (a: Algo) => ({ '256': 'SHA-256', '384': 'SHA-384', '512': 'SHA-512' }[a.slice(2)])!;
  const isHS = (a: Algo) => a.startsWith('HS');
  const isRS = (a: Algo) => a.startsWith('RS');
  const isES = (a: Algo) => a.startsWith('ES');
  const ecCurveFromAlgo = (a: Algo) => (a === 'ES256' ? 'P-256' : 'P-384');

  // ---- WebCrypto key import ----
  async function importHmac(usages: KeyUsage[]) {
    const raw = secretB64.checked ? b64urlDecodeBytes(secretEl.value.trim().replace(/-/g, '+').replace(/_/g, '/'))
                                  : new TextEncoder().encode(secretEl.value);
    return crypto.subtle.importKey('raw', raw, { name: 'HMAC', hash: hashFromAlgo(algo) }, false, usages);
  }
  async function importRsaPublic() {
    return crypto.subtle.importKey('spki', pemToDer(pubkeyEl.value),
      { name: 'RSASSA-PKCS1-v1_5', hash: hashFromAlgo(algo) }, false, ['verify']);
  }
  async function importRsaPrivate() {
    return crypto.subtle.importKey('pkcs8', pemToDer(privkeyEl.value),
      { name: 'RSASSA-PKCS1-v1_5', hash: hashFromAlgo(algo) }, false, ['sign']);
  }
  async function importEcPublic() {
    return crypto.subtle.importKey('spki', pemToDer(pubkeyEl.value),
      { name: 'ECDSA', namedCurve: ecCurveFromAlgo(algo) }, false, ['verify']);
  }
  async function importEcPrivate() {
    return crypto.subtle.importKey('pkcs8', pemToDer(privkeyEl.value),
      { name: 'ECDSA', namedCurve: ecCurveFromAlgo(algo) }, false, ['sign']);
  }

  async function sign(signingInput: string): Promise<Uint8Array | null> {
    const data = new TextEncoder().encode(signingInput);
    if (isHS(algo)) {
      if (!secretEl.value) return null;
      const key = await importHmac(['sign']);
      return new Uint8Array(await crypto.subtle.sign('HMAC', key, data));
    }
    if (isRS(algo)) {
      if (!privkeyEl.value.trim()) return null;
      const key = await importRsaPrivate();
      return new Uint8Array(await crypto.subtle.sign('RSASSA-PKCS1-v1_5', key, data));
    }
    if (isES(algo)) {
      if (!privkeyEl.value.trim()) return null;
      const key = await importEcPrivate();
      // WebCrypto returns raw r||s for ECDSA, which is exactly what JWT expects.
      return new Uint8Array(await crypto.subtle.sign({ name: 'ECDSA', hash: hashFromAlgo(algo) }, key, data));
    }
    return null;
  }

  async function verify(signingInput: string, sig: Uint8Array): Promise<boolean> {
    const data = new TextEncoder().encode(signingInput);
    if (isHS(algo)) {
      if (!secretEl.value) throw new Error('NEED_SECRET');
      const key = await importHmac(['verify']);
      return crypto.subtle.verify('HMAC', key, sig, data);
    }
    if (isRS(algo)) {
      if (!pubkeyEl.value.trim()) throw new Error('NEED_PUBKEY');
      const key = await importRsaPublic();
      return crypto.subtle.verify('RSASSA-PKCS1-v1_5', key, sig, data);
    }
    if (isES(algo)) {
      if (!pubkeyEl.value.trim()) throw new Error('NEED_PUBKEY');
      const key = await importEcPublic();
      return crypto.subtle.verify({ name: 'ECDSA', hash: hashFromAlgo(algo) }, key, sig, data);
    }
    return false;
  }

  // ---- UI status ----
  const setStatus = (kind: 'ok' | 'bad' | 'idle', msg: string) => {
    verifyBox.className = 'mt-3 px-4 py-2 rounded-lg text-sm border';
    if (kind === 'ok')  verifyBox.className += ' border-green-200 bg-green-50 text-green-700';
    if (kind === 'bad') verifyBox.className += ' border-red-200 bg-red-50 text-red-600';
    if (kind === 'idle')verifyBox.className += ' border-gray-200 bg-gray-50 text-gray-500';
    verifyText.textContent = msg;
  };
  const showErr = (m: string) => { errBox.textContent = m; errBox.classList.remove('hidden'); };
  const hideErr = () => errBox.classList.add('hidden');

  const updateKeyBoxVisibility = () => {
    if (isHS(algo)) { secretBox.classList.remove('hidden'); asymBox.classList.add('hidden'); }
    else            { secretBox.classList.add('hidden');    asymBox.classList.remove('hidden'); }
  };

  // ---- Decode flow: encoded -> header/payload/verify ----
  async function decodeAndVerify() {
    hideErr();
    const raw = encoded.value.trim();
    if (!raw) { setStatus('idle', '输入 token 和密钥以验证签名'); return; }
    const parts = raw.split('.');
    if (parts.length !== 3) { showErr('JWT 格式错误：应为 header.payload.signature'); setStatus('idle', '—'); return; }

    let headerJson = '', payloadJson = '';
    try { headerJson = b64urlDecodeString(parts[0]); } catch { showErr('Header base64 无效'); return; }
    try { payloadJson = b64urlDecodeString(parts[1]); } catch { showErr('Payload base64 无效'); return; }

    let headerObj: any;
    try { headerObj = JSON.parse(headerJson); } catch { showErr('Header 不是合法 JSON'); return; }

    try { headerEl.value = JSON.stringify(headerObj, null, 2); } catch { headerEl.value = headerJson; }
    try { payloadEl.value = JSON.stringify(JSON.parse(payloadJson), null, 2); } catch { payloadEl.value = payloadJson; }

    // Sync algorithm from header.alg (if supported and different)
    if (typeof headerObj.alg === 'string' && headerObj.alg !== algo && algoIsSupported(headerObj.alg)) {
      setAlgo(headerObj.alg as Algo, false);
    }

    try {
      const sig = b64urlDecodeBytes(parts[2]);
      const ok = await verify(`${parts[0]}.${parts[1]}`, sig);
      setStatus(ok ? 'ok' : 'bad', ok ? '签名验证通过' : '签名不匹配');
    } catch (e: any) {
      if (e.message === 'NEED_SECRET') setStatus('idle', '输入 secret 以验证签名');
      else if (e.message === 'NEED_PUBKEY') setStatus('idle', '粘贴 public key 以验证签名');
      else setStatus('bad', `验证失败：${e.message || e}`);
    }
  }

  const supportedAlgos: Algo[] = ['HS256','HS384','HS512','RS256','RS384','RS512','ES256','ES384'];
  const algoIsSupported = (a: string): a is Algo => (supportedAlgos as string[]).includes(a);

  // ---- Encode flow: header/payload/key -> encoded ----
  async function encodeFromDecoded() {
    hideErr();
    let headerObj: any, payloadObj: any;
    try { headerObj = JSON.parse(headerEl.value); } catch { showErr('Header 不是合法 JSON'); return; }
    try { payloadObj = JSON.parse(payloadEl.value); } catch { showErr('Payload 不是合法 JSON'); return; }

    if (!headerObj.alg) headerObj.alg = algo;
    if (!headerObj.typ) headerObj.typ = 'JWT';

    const h = b64urlEncodeString(JSON.stringify(headerObj));
    const p = b64urlEncodeString(JSON.stringify(payloadObj));
    const signingInput = `${h}.${p}`;

    try {
      const sig = await sign(signingInput);
      if (!sig) {
        encoded.value = `${signingInput}.`;
        setStatus('idle', isHS(algo) ? '输入 secret 生成签名' : '粘贴 private key 生成签名');
        return;
      }
      const token = `${signingInput}.${b64urlEncodeBytes(sig)}`;
      encoded.value = token;
      // Re-verify the signature we just produced to refresh status
      try {
        const ok = await verify(signingInput, sig);
        setStatus(ok ? 'ok' : 'bad', ok ? '签名验证通过' : '签名不匹配');
      } catch { setStatus('idle', '已签发 · 粘贴 public key/secret 以验证'); }
    } catch (e: any) {
      showErr(`签名失败：${e.message || e}`);
    }
  }

  // ---- Algorithm selection ----
  function setAlgo(next: Algo, triggerEncode: boolean) {
    algo = next;
    algoBtns.forEach(btn => {
      const active = btn.dataset.algo === algo;
      btn.classList.toggle('bg-[#171717]', active);
      btn.classList.toggle('text-white', active);
      btn.classList.toggle('text-gray-600', !active);
    });
    updateKeyBoxVisibility();

    // Keep header.alg in sync with the selected algorithm when the user picks one.
    try {
      const h = JSON.parse(headerEl.value);
      if (h && typeof h === 'object') {
        h.alg = algo;
        headerEl.value = JSON.stringify(h, null, 2);
      }
    } catch { /* non-JSON header, leave alone */ }

    if (triggerEncode) scheduleEncode();
    else scheduleDecode();
  }

  algoBtns.forEach(btn => btn.addEventListener('click', () => setAlgo(btn.dataset.algo as Algo, true)));

  // ---- Debounced reactivity ----
  let t: number | undefined;
  const debounce = (fn: () => void, ms = 120) => {
    if (t) clearTimeout(t);
    t = window.setTimeout(fn, ms);
  };
  const scheduleDecode = () => debounce(async () => {
    if (updatingFromDecoded) return;
    updatingFromEncoded = true;
    await decodeAndVerify();
    updatingFromEncoded = false;
  });
  const scheduleEncode = () => debounce(async () => {
    if (updatingFromEncoded) return;
    updatingFromDecoded = true;
    await encodeFromDecoded();
    updatingFromDecoded = false;
  });

  encoded.addEventListener('input', scheduleDecode);
  headerEl.addEventListener('input', scheduleEncode);
  payloadEl.addEventListener('input', scheduleEncode);
  secretEl.addEventListener('input', () => { if (isHS(algo)) scheduleEncode(); });
  secretB64.addEventListener('change', () => { if (isHS(algo)) scheduleEncode(); });
  pubkeyEl.addEventListener('input', scheduleDecode);
  privkeyEl.addEventListener('input', scheduleEncode);

  // ---- Sample preload (jwt.io default) ----
  const loadSample = () => {
    setAlgo('HS256', false);
    headerEl.value = JSON.stringify({ alg: 'HS256', typ: 'JWT' }, null, 2);
    payloadEl.value = JSON.stringify({ sub: '1234567890', name: 'John Doe', iat: 1516239022 }, null, 2);
    secretEl.value = 'your-256-bit-secret';
    secretB64.checked = false;
    scheduleEncode();
  };
  sampleBtn.addEventListener('click', loadSample);

  // ---- Copy ----
  copyBtn.addEventListener('click', async () => {
    if (!encoded.value) return;
    await navigator.clipboard.writeText(encoded.value);
    const old = copyBtn.textContent;
    copyBtn.textContent = '已复制';
    setTimeout(() => { copyBtn.textContent = old; }, 1200);
  });

  // ---- Init: show sample so the page is useful on first paint ----
  loadSample();
</script>
