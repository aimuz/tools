---
interface Props {
  placeholder?: string;
}

const { placeholder = '搜索工具...' } = Astro.props;
---

<div class="relative max-w-xl mx-auto">
  <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
  </div>
  <input
    type="text"
    id="tool-search"
    class="w-full pl-11 pr-4 py-3 bg-white border border-gray-200 rounded-lg text-sm text-[#171717] placeholder-gray-400 focus:outline-none focus:border-[#171717] transition-colors"
    placeholder={placeholder}
  />
</div>

<script>
  const searchInput = document.getElementById('tool-search');
  const toolCards = document.querySelectorAll('[data-tool-card]');

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();

    toolCards.forEach((card) => {
      const title = card.getAttribute('data-tool-title') || '';
      const description = card.getAttribute('data-tool-desc') || '';

      if (title.includes(query) || description.includes(query)) {
        (card as HTMLElement).style.display = '';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  });
</script>
