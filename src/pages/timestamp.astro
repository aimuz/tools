---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="Unix 时间戳转换 - 时间戳转日期/日期转时间戳 | WizGo"
  description="免费在线 Unix 时间戳转换工具，支持秒/毫秒、UTC 和本地时区、ISO 8601 格式互转，实时显示当前时间戳，一键复制。浏览器本地处理不上传。"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Unix 时间戳转换',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    description: 'Unix 时间戳和日期互转工具，支持秒/毫秒、UTC/本地时区',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: 'https://wizgo.xyz/timestamp',
  })} slot="head" />
  <Header />

  <main class="flex-1 py-10">
    <div class="max-w-[960px] mx-auto px-6">
      <!-- Title -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-semibold text-[#171717] mb-2">时间戳转换</h1>
        <p class="text-gray-500">Unix 时间戳和日期互转 · 支持秒 / 毫秒 / ISO 8601</p>
      </div>

      <!-- Current time -->
      <section class="mb-8 p-5 bg-white border border-gray-200 rounded-xl">
        <div class="flex items-center justify-between mb-4">
          <span class="text-sm font-medium text-[#171717]">当前时间</span>
          <button id="pause-btn" class="text-xs text-gray-400 hover:text-[#171717]" data-running="1">暂停</button>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="row" data-label="Unix 秒">
            <span class="text-xs text-gray-400">Unix 秒</span>
            <div class="flex items-center gap-2">
              <code id="now-sec" class="flex-1 font-mono text-lg text-[#171717] tabular-nums">—</code>
              <button class="copy-btn text-xs text-gray-400 hover:text-[#171717]" data-target="now-sec">复制</button>
            </div>
          </div>
          <div class="row" data-label="Unix 毫秒">
            <span class="text-xs text-gray-400">Unix 毫秒</span>
            <div class="flex items-center gap-2">
              <code id="now-ms" class="flex-1 font-mono text-lg text-[#171717] tabular-nums">—</code>
              <button class="copy-btn text-xs text-gray-400 hover:text-[#171717]" data-target="now-ms">复制</button>
            </div>
          </div>
          <div class="row">
            <span class="text-xs text-gray-400">本地时间</span>
            <div class="flex items-center gap-2">
              <code id="now-local" class="flex-1 font-mono text-sm text-[#171717]">—</code>
              <button class="copy-btn text-xs text-gray-400 hover:text-[#171717]" data-target="now-local">复制</button>
            </div>
          </div>
          <div class="row">
            <span class="text-xs text-gray-400">ISO 8601 (UTC)</span>
            <div class="flex items-center gap-2">
              <code id="now-iso" class="flex-1 font-mono text-sm text-[#171717]">—</code>
              <button class="copy-btn text-xs text-gray-400 hover:text-[#171717]" data-target="now-iso">复制</button>
            </div>
          </div>
        </div>
        <p id="tz-info" class="text-xs text-gray-400 mt-3">时区：—</p>
      </section>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Timestamp -> Date -->
        <section>
          <div class="flex justify-between items-center mb-2">
            <span class="text-sm font-medium text-[#171717]">时间戳 → 日期</span>
            <button id="fill-now-ts" class="text-xs text-gray-400 hover:text-[#171717]">填入当前</button>
          </div>
          <div class="flex gap-2 mb-2">
            <button data-unit="auto" class="unit-btn px-3 py-1 text-xs rounded-full border border-gray-200 bg-[#171717] text-white">自动</button>
            <button data-unit="s" class="unit-btn px-3 py-1 text-xs rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">秒</button>
            <button data-unit="ms" class="unit-btn px-3 py-1 text-xs rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">毫秒</button>
          </div>
          <input
            id="ts-input"
            type="text"
            inputmode="numeric"
            placeholder="如：1516239022 或 1516239022000"
            class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg font-mono text-sm focus:outline-none focus:border-[#171717]"
          />
          <div class="mt-4 space-y-2">
            <div class="row-out"><span class="text-xs text-gray-400">本地时间</span><div class="flex items-center gap-2"><code id="t2d-local" class="flex-1 font-mono text-sm text-[#171717] break-all">—</code><button class="copy-btn text-xs text-gray-400 hover:text-[#171717]" data-target="t2d-local">复制</button></div></div>
            <div class="row-out"><span class="text-xs text-gray-400">UTC 时间</span><div class="flex items-center gap-2"><code id="t2d-utc" class="flex-1 font-mono text-sm text-[#171717] break-all">—</code><button class="copy-btn text-xs text-gray-400 hover:text-[#171717]" data-target="t2d-utc">复制</button></div></div>
            <div class="row-out"><span class="text-xs text-gray-400">ISO 8601</span><div class="flex items-center gap-2"><code id="t2d-iso" class="flex-1 font-mono text-sm text-[#171717] break-all">—</code><button class="copy-btn text-xs text-gray-400 hover:text-[#171717]" data-target="t2d-iso">复制</button></div></div>
            <div class="row-out"><span class="text-xs text-gray-400">相对时间</span><code id="t2d-rel" class="font-mono text-sm text-[#171717]">—</code></div>
          </div>
          <p id="t2d-err" class="hidden mt-3 text-xs text-red-500"></p>
        </section>

        <!-- Date -> Timestamp -->
        <section>
          <div class="flex justify-between items-center mb-2">
            <span class="text-sm font-medium text-[#171717]">日期 → 时间戳</span>
            <button id="fill-now-date" class="text-xs text-gray-400 hover:text-[#171717]">填入当前</button>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <input
              id="date-local"
              type="datetime-local"
              step="1"
              class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg font-mono text-sm focus:outline-none focus:border-[#171717]"
            />
            <input
              id="date-str"
              type="text"
              placeholder="或粘贴 ISO 字符串：2024-01-18T03:30:22Z"
              class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg font-mono text-sm focus:outline-none focus:border-[#171717]"
            />
          </div>
          <div class="mt-4 space-y-2">
            <div class="row-out"><span class="text-xs text-gray-400">Unix 秒</span><div class="flex items-center gap-2"><code id="d2t-sec" class="flex-1 font-mono text-sm text-[#171717] tabular-nums">—</code><button class="copy-btn text-xs text-gray-400 hover:text-[#171717]" data-target="d2t-sec">复制</button></div></div>
            <div class="row-out"><span class="text-xs text-gray-400">Unix 毫秒</span><div class="flex items-center gap-2"><code id="d2t-ms" class="flex-1 font-mono text-sm text-[#171717] tabular-nums">—</code><button class="copy-btn text-xs text-gray-400 hover:text-[#171717]" data-target="d2t-ms">复制</button></div></div>
            <div class="row-out"><span class="text-xs text-gray-400">ISO 8601 (UTC)</span><div class="flex items-center gap-2"><code id="d2t-iso" class="flex-1 font-mono text-sm text-[#171717] break-all">—</code><button class="copy-btn text-xs text-gray-400 hover:text-[#171717]" data-target="d2t-iso">复制</button></div></div>
          </div>
          <p id="d2t-err" class="hidden mt-3 text-xs text-red-500"></p>
        </section>
      </div>

      <!-- Hint -->
      <p class="text-xs text-gray-400 mt-8 text-center">
        Unix 纪元：1970-01-01 00:00:00 UTC · 秒级时间戳 10 位 · 毫秒级 13 位
      </p>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;
  const pad = (n: number, len = 2) => n.toString().padStart(len, '0');

  // ---- Formatters ----
  const fmtLocal = (d: Date) =>
    `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;

  const fmtUtc = (d: Date) =>
    `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())} UTC`;

  const fmtIso = (d: Date) => d.toISOString();

  const fmtRelative = (d: Date) => {
    const diffMs = d.getTime() - Date.now();
    const abs = Math.abs(diffMs);
    const rtf = new Intl.RelativeTimeFormat('zh-CN', { numeric: 'auto' });
    const units: [Intl.RelativeTimeFormatUnit, number][] = [
      ['year',   365 * 24 * 3600 * 1000],
      ['month',  30  * 24 * 3600 * 1000],
      ['day',         24 * 3600 * 1000],
      ['hour',             3600 * 1000],
      ['minute',             60 * 1000],
      ['second',                  1000],
    ];
    for (const [unit, ms] of units) {
      if (abs >= ms || unit === 'second') {
        return rtf.format(Math.round(diffMs / ms), unit);
      }
    }
    return '刚刚';
  };

  // ---- Current time panel ----
  const nowSec = $('now-sec');
  const nowMs = $('now-ms');
  const nowLocal = $('now-local');
  const nowIso = $('now-iso');
  const pauseBtn = $('pause-btn');
  const tzInfo = $('tz-info');

  const renderNow = () => {
    const now = new Date();
    nowSec.textContent = Math.floor(now.getTime() / 1000).toString();
    nowMs.textContent = now.getTime().toString();
    nowLocal.textContent = fmtLocal(now);
    nowIso.textContent = fmtIso(now);
  };

  const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
  const tzOffsetMin = -new Date().getTimezoneOffset();
  const tzSign = tzOffsetMin >= 0 ? '+' : '-';
  const tzH = pad(Math.floor(Math.abs(tzOffsetMin) / 60));
  const tzM = pad(Math.abs(tzOffsetMin) % 60);
  tzInfo.textContent = `时区：${tz} · UTC${tzSign}${tzH}:${tzM}`;

  renderNow();
  let tickId: number | undefined = window.setInterval(renderNow, 1000);
  pauseBtn.addEventListener('click', () => {
    const running = pauseBtn.dataset.running === '1';
    if (running) {
      if (tickId) window.clearInterval(tickId);
      tickId = undefined;
      pauseBtn.dataset.running = '0';
      pauseBtn.textContent = '继续';
    } else {
      renderNow();
      tickId = window.setInterval(renderNow, 1000);
      pauseBtn.dataset.running = '1';
      pauseBtn.textContent = '暂停';
    }
  });

  // ---- Timestamp → Date ----
  const tsInput = $<HTMLInputElement>('ts-input');
  const t2dLocal = $('t2d-local');
  const t2dUtc = $('t2d-utc');
  const t2dIso = $('t2d-iso');
  const t2dRel = $('t2d-rel');
  const t2dErr = $('t2d-err');
  const unitBtns = document.querySelectorAll<HTMLButtonElement>('.unit-btn');
  let unit: 'auto' | 's' | 'ms' = 'auto';

  const resetT2d = (err?: string) => {
    [t2dLocal, t2dUtc, t2dIso, t2dRel].forEach(el => el.textContent = '—');
    if (err) { t2dErr.textContent = err; t2dErr.classList.remove('hidden'); }
    else { t2dErr.classList.add('hidden'); }
  };

  const convertTimestamp = () => {
    const raw = tsInput.value.trim();
    if (!raw) { resetT2d(); return; }
    if (!/^-?\d+(\.\d+)?$/.test(raw)) { resetT2d('必须是数字'); return; }
    let n = Number(raw);
    if (!Number.isFinite(n)) { resetT2d('数字超出范围'); return; }

    let ms: number;
    if (unit === 's')      ms = n * 1000;
    else if (unit === 'ms') ms = n;
    else ms = Math.abs(n) >= 1e12 ? n : n * 1000;  // auto: ≥1e12 视为毫秒

    const d = new Date(ms);
    if (isNaN(d.getTime())) { resetT2d('无效的时间戳'); return; }

    t2dErr.classList.add('hidden');
    t2dLocal.textContent = fmtLocal(d);
    t2dUtc.textContent = fmtUtc(d);
    t2dIso.textContent = fmtIso(d);
    t2dRel.textContent = fmtRelative(d);
  };

  tsInput.addEventListener('input', convertTimestamp);
  unitBtns.forEach(btn => btn.addEventListener('click', () => {
    unit = btn.dataset.unit as typeof unit;
    unitBtns.forEach(b => {
      const active = b === btn;
      b.classList.toggle('bg-[#171717]', active);
      b.classList.toggle('text-white', active);
      b.classList.toggle('text-gray-600', !active);
    });
    convertTimestamp();
  }));

  $('fill-now-ts').addEventListener('click', () => {
    tsInput.value = Math.floor(Date.now() / 1000).toString();
    convertTimestamp();
  });

  // ---- Date → Timestamp ----
  const dateLocal = $<HTMLInputElement>('date-local');
  const dateStr = $<HTMLInputElement>('date-str');
  const d2tSec = $('d2t-sec');
  const d2tMs = $('d2t-ms');
  const d2tIso = $('d2t-iso');
  const d2tErr = $('d2t-err');

  const resetD2t = (err?: string) => {
    [d2tSec, d2tMs, d2tIso].forEach(el => el.textContent = '—');
    if (err) { d2tErr.textContent = err; d2tErr.classList.remove('hidden'); }
    else { d2tErr.classList.add('hidden'); }
  };

  const renderDate = (d: Date) => {
    d2tErr.classList.add('hidden');
    d2tSec.textContent = Math.floor(d.getTime() / 1000).toString();
    d2tMs.textContent = d.getTime().toString();
    d2tIso.textContent = fmtIso(d);
  };

  dateLocal.addEventListener('input', () => {
    if (!dateLocal.value) { resetD2t(); return; }
    // <input type="datetime-local"> value is interpreted as local time by new Date()
    const d = new Date(dateLocal.value);
    if (isNaN(d.getTime())) { resetD2t('日期无效'); return; }
    dateStr.value = '';
    renderDate(d);
  });

  dateStr.addEventListener('input', () => {
    const raw = dateStr.value.trim();
    if (!raw) { resetD2t(); return; }
    const d = new Date(raw);
    if (isNaN(d.getTime())) { resetD2t('无法解析的日期字符串'); return; }
    dateLocal.value = '';
    renderDate(d);
  });

  $('fill-now-date').addEventListener('click', () => {
    const now = new Date();
    // datetime-local wants YYYY-MM-DDTHH:mm:ss in local time
    const v = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}T${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
    dateLocal.value = v;
    dateStr.value = '';
    renderDate(now);
  });

  // ---- Copy buttons ----
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const target = btn.dataset.target!;
      const text = document.getElementById(target)?.textContent?.trim();
      if (!text || text === '—') return;
      try {
        await navigator.clipboard.writeText(text);
        const orig = btn.textContent;
        btn.textContent = '已复制';
        setTimeout(() => { btn.textContent = orig; }, 1200);
      } catch {}
    });
  });
</script>
