---
import UrlEncodePage from '../../components/pages/UrlEncodePage.astro';
import { isLocale, type Locale } from '../../i18n/config';

export const getStaticPaths = () => [{ params: { locale: 'en' } }, { params: { locale: 'zh-TW' } }, { params: { locale: 'ja' } }, { params: { locale: 'ko' } }];

const { locale } = Astro.params;
if (!locale || !isLocale(locale)) throw new Error(`Invalid locale: ${locale}`);
---

<UrlEncodePage locale={locale as Locale} />
