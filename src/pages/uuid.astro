---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="UUID 生成器 - 在线批量生成唯一标识符 | WizGo"
  description="免费在线 UUID 生成器，支持批量生成、多种格式（标准/无横线/大写）、一键复制。使用密码学安全随机数生成，浏览器本地处理不上传。"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'UUID 生成器',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    description: '在线批量生成 UUID 唯一标识符，支持多种格式',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: 'https://wizgo.xyz/uuid',
  })} slot="head" />
  <Header />

  <main class="flex-1 py-10">
    <div class="max-w-[800px] mx-auto px-6">
      <!-- Title -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-semibold text-[#171717] mb-2">UUID 生成器</h1>
        <p class="text-gray-500">批量生成唯一标识符 · 标准格式 / 无横线 / 大写 · 本地生成不上传</p>
      </div>

      <!-- Settings -->
      <section class="mb-6 p-5 bg-white border border-gray-200 rounded-xl">
        <div class="grid sm:grid-cols-3 gap-4">
          <!-- Quantity -->
          <div>
            <label class="block text-sm text-gray-500 mb-2">生成数量</label>
            <div class="flex flex-wrap gap-2">
              <button data-qty="1" class="qty-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">1</button>
              <button data-qty="5" class="qty-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 bg-[#171717] text-white">5</button>
              <button data-qty="10" class="qty-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">10</button>
              <button data-qty="50" class="qty-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">50</button>
              <button data-qty="100" class="qty-btn px-3 py-1.5 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]">100</button>
            </div>
          </div>

          <!-- Format -->
          <div>
            <label class="block text-sm text-gray-500 mb-2">格式选项</label>
            <div class="space-y-2">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" id="no-dashes" class="accent-[#171717]" />
                <span class="text-sm text-gray-600">移除横线 (-)</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" id="uppercase" class="accent-[#171717]" />
                <span class="text-sm text-gray-600">大写字母</span>
              </label>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex items-end">
            <button id="generate-btn" class="w-full px-4 py-2 bg-[#171717] text-white text-sm rounded-lg hover:bg-gray-800 transition-colors">
              重新生成
            </button>
          </div>
        </div>
      </section>

      <!-- Results -->
      <section>
        <div class="flex justify-between items-center mb-3">
          <span class="text-sm text-gray-500">生成结果</span>
          <button id="copy-all-btn" class="text-sm text-gray-400 hover:text-[#171717]">复制全部</button>
        </div>

        <div id="uuid-list" class="space-y-2">
          <!-- UUID items will be inserted here -->
        </div>

        <!-- Empty state (hidden by default) -->
        <div id="empty-state" class="hidden text-center py-12 border border-dashed border-gray-200 rounded-xl">
          <p class="text-gray-400 text-sm">点击"重新生成"按钮生成 UUID</p>
        </div>
      </section>

      <!-- Info -->
      <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-xl">
        <h3 class="text-sm font-medium text-[#171717] mb-2">关于 UUID</h3>
        <p class="text-xs text-gray-500 leading-relaxed">
          UUID（通用唯一标识符）是一种 128 位的标识符，通常表示为 32 个十六进制数字，分为 5 组。
          本工具使用浏览器内置的加密安全随机数生成器（crypto.getRandomValues）生成 UUID v4 版本，
          确保生成的标识符具有极高的唯一性，适合用于数据库主键、会话标识、API 密钥等场景。
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

  // Elements
  const qtyBtns = document.querySelectorAll<HTMLButtonElement>('.qty-btn');
  const noDashesCheckbox = $<HTMLInputElement>('no-dashes');
  const uppercaseCheckbox = $<HTMLInputElement>('uppercase');
  const generateBtn = $('generate-btn');
  const copyAllBtn = $('copy-all-btn');
  const uuidList = $('uuid-list');

  let quantity = 5;

  // Generate a single UUID v4 using crypto.getRandomValues
  const generateUUID = (): string => {
    const bytes = new Uint8Array(16);
    crypto.getRandomValues(bytes);

    // Set version (4) and variant bits
    bytes[6] = (bytes[6] & 0x0f) | 0x40;
    bytes[8] = (bytes[8] & 0x3f) | 0x80;

    // Convert to hex string
    const hex = Array.from(bytes, (b) => b.toString(16).padStart(2, '0')).join('');

    // Format with dashes: xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx
    let uuid = `${hex.slice(0, 8)}-${hex.slice(8, 12)}-${hex.slice(12, 16)}-${hex.slice(16, 20)}-${hex.slice(20)}`;

    // Apply format options
    if (noDashesCheckbox.checked) {
      uuid = uuid.replace(/-/g, '');
    }
    if (uppercaseCheckbox.checked) {
      uuid = uuid.toUpperCase();
    }

    return uuid;
  };

  // Generate and display UUIDs
  const generateAndDisplay = () => {
    uuidList.innerHTML = '';

    for (let i = 0; i < quantity; i++) {
      const uuid = generateUUID();
      const item = document.createElement('div');
      item.className = 'flex items-center gap-3 p-3 bg-white border border-gray-200 rounded-lg group hover:border-[#171717] transition-colors';
      item.innerHTML = `
        <code class="flex-1 font-mono text-sm text-[#171717] break-all">${uuid}</code>
        <button class="copy-btn text-xs text-gray-400 hover:text-[#171717] opacity-0 group-hover:opacity-100 transition-opacity" data-uuid="${uuid}">
          复制
        </button>
      `;
      uuidList.appendChild(item);
    }

    // Add copy listeners
    uuidList.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const uuid = btn.dataset.uuid!;
        try {
          await navigator.clipboard.writeText(uuid);
          const old = btn.textContent;
          btn.textContent = '已复制';
          btn.classList.add('text-green-600');
          setTimeout(() => {
            btn.textContent = old;
            btn.classList.remove('text-green-600');
          }, 1200);
        } catch {}
      });
    });
  };

  // Quantity selection
  qtyBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      quantity = parseInt(btn.dataset.qty!, 10);
      qtyBtns.forEach(b => {
        const active = b === btn;
        b.classList.toggle('bg-[#171717]', active);
        b.classList.toggle('text-white', active);
        b.classList.toggle('text-gray-600', !active);
      });
      generateAndDisplay();
    });
  });

  // Format option changes
  noDashesCheckbox.addEventListener('change', generateAndDisplay);
  uppercaseCheckbox.addEventListener('change', generateAndDisplay);

  // Generate button
  generateBtn.addEventListener('click', generateAndDisplay);

  // Copy all button
  copyAllBtn.addEventListener('click', async () => {
    const uuids = Array.from(uuidList.querySelectorAll('code')).map(el => el.textContent).join('\n');
    if (!uuids) return;
    try {
      await navigator.clipboard.writeText(uuids);
      const old = copyAllBtn.textContent;
      copyAllBtn.textContent = '已复制全部';
      setTimeout(() => copyAllBtn.textContent = old, 1200);
    } catch {}
  });

  // Initial generation
  generateAndDisplay();
</script>
