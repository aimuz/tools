---
import { useTranslations } from '../i18n';
import { DEFAULT_LOCALE, type Locale } from '../i18n/config';
import {
  absoluteUrl,
  alternateOgLocales,
  buildHreflangEntries,
  ogLocale,
  stripLocaleFromPath,
} from '../i18n/seo';

interface Props {
  title: string;
  description?: string;
  /** Absolute URL of the social share image. Falls back to the site logo. */
  ogImage?: string;
  /** Override the auto-derived canonical URL. */
  canonical?: string;
  /** og:type — defaults to "website"; use "article" for blog posts. */
  ogType?: 'website' | 'article';
  /** Page locale. Defaults to zh-CN; required for any non-default locale page. */
  locale?: Locale;
}

const {
  title,
  ogImage,
  canonical,
  ogType = 'website',
  locale = DEFAULT_LOCALE,
} = Astro.props;

const t = useTranslations(locale);
const description = Astro.props.description ?? t.common.siteTagline;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://wizgo.xyz';
const localePath = '/' + stripLocaleFromPath(Astro.url.pathname);
const canonicalUrl = canonical ?? absoluteUrl(locale, localePath, siteUrl);
const socialImage = ogImage ?? `${siteUrl}/favicon.svg`;
const hreflangEntries = buildHreflangEntries(localePath, siteUrl);
const ogLocaleValue = ogLocale(locale);
const ogAlternates = alternateOgLocales(locale);

const manifestHref = locale === DEFAULT_LOCALE ? '/manifest.webmanifest' : `/${locale}/manifest.webmanifest`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#171717" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {hreflangEntries.map((entry) => (
      <link rel="alternate" hreflang={entry.hreflang} href={entry.href} />
    ))}

    <!-- PWA -->
    <link rel="manifest" href={manifestHref} />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={t.common.siteName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:locale" content={ogLocaleValue} />
    {ogAlternates.map((alt) => (
      <meta property="og:locale:alternate" content={alt} />
    ))}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
