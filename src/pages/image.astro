---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Container from '../components/layout/Container.astro';
import Button from '../components/ui/Button.astro';
import ProgressBar from '../components/ui/ProgressBar.astro';
import Badge from '../components/ui/Badge.astro';
---

<Layout title="图片格式转换 - Tools Hub">
  <script is:inline src="/wasm-vips/vips.js"></script>
  <Header />
  
  <main class="flex-1 py-12">
    <Container>
      <div class="max-w-3xl mx-auto">
        <h1 class="text-[40px] font-semibold text-vercel-black tracking-tight-2.4 mb-4">
          图片格式转换
        </h1>
        <p class="text-gray-600 mb-8">支持 PNG、JPEG、BMP、GIF、TGA、QOI 格式互转</p>
        
        <!-- WASM Loading Status -->
        <div id="wasm-status" class="mb-4 p-4 rounded-comfortable bg-blue-50 text-blue-700 text-sm">
          正在加载 WASM 模块...
        </div>
        
        <!-- Step 1: Upload -->
        <section class="mb-8" id="upload-section">
          <h2 class="text-sm font-medium text-gray-600 uppercase tracking-wide mb-4">
            1. 选择文件
          </h2>
          <div 
            id="upload-zone"
            class="relative w-full min-h-[280px] rounded-comfortable bg-vercel-white shadow-border
                   flex flex-col items-center justify-center gap-4
                   border-2 border-dashed border-gray-200 hover:border-vercel-black/20
                   transition-all duration-200 cursor-pointer group"
          >
            <div class="p-4 rounded-full bg-gray-50 group-hover:bg-gray-100 transition-colors">
              <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
              </svg>
            </div>
            <div class="text-center">
              <p class="text-lg font-medium text-vercel-black">拖放文件到这里</p>
              <p class="text-sm text-gray-600 mt-1">或点击选择文件</p>
            </div>
            <div class="flex gap-2 mt-2">
              <Badge>PNG</Badge>
              <Badge>JPG</Badge>
              <Badge>GIF</Badge>
              <Badge>BMP</Badge>
            </div>
            <p class="text-xs text-gray-400 mt-2">最大文件：50MB</p>
            <input type="file" id="file-input" class="hidden" accept="image/*" multiple />
          </div>
        </section>

        <!-- File List -->
        <section id="file-list-section" class="mb-8 hidden">
          <h2 class="text-sm font-medium text-gray-600 uppercase tracking-wide mb-4">
            已选择文件
          </h2>
          <div id="file-list" class="space-y-3">
            <!-- Files will be inserted here -->
          </div>
        </section>

        <!-- Step 2: Configure -->
        <section id="config-section" class="mb-8 hidden">
          <h2 class="text-sm font-medium text-gray-600 uppercase tracking-wide mb-4">
            2. 转换设置
          </h2>
          <div class="p-6 rounded-comfortable bg-vercel-white shadow-border">
            <div class="mb-6">
              <label class="block text-sm font-medium text-vercel-black mb-2">
                目标格式
              </label>
              <select id="output-format" class="w-full px-4 py-2 rounded-standard border border-gray-200 focus:border-vercel-black focus:outline-none">
                <option value="png">PNG</option>
                <option value="jpeg">JPEG</option>
                <option value="bmp">BMP</option>
                <option value="gif">GIF</option>
              </select>
            </div>
            
            <div class="mb-6" id="quality-section">
              <label class="block text-sm font-medium text-vercel-black mb-2">
                JPEG 质量: <span id="quality-value">85</span>%
              </label>
              <input 
                type="range" 
                id="quality-slider" 
                min="1" 
                max="100" 
                value="85"
                class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer"
              />
            </div>
          </div>
        </section>

        <!-- Progress -->
        <section id="progress-section" class="mb-8 hidden">
          <ProgressBar progress={0} label="转换进度" id="convert-progress" />
          <p id="progress-text" class="text-sm text-gray-600 mt-2 text-center">准备转换...</p>
        </section>

        <!-- Convert Button -->
        <section id="convert-section" class="mb-8 hidden">
          <Button variant="primary" size="lg" class="w-full" id="convert-btn">
            开始转换
          </Button>
        </section>

        <!-- Results -->
        <section id="results-section" class="hidden">
          <h2 class="text-sm font-medium text-gray-600 uppercase tracking-wide mb-4">
            转换完成
          </h2>
          <div id="results-list" class="space-y-3">
            <!-- Results will be inserted here -->
          </div>
        </section>
      </div>
    </Container>
  </main>
  
  <Footer />
</Layout>

<script>
  import { getImageConverter } from '../wasm/vips-converter.js';

  // File handling
  const uploadZone = document.getElementById('upload-zone');
  const fileInput = document.getElementById('file-input');
  const fileListSection = document.getElementById('file-list-section');
  const fileList = document.getElementById('file-list');
  const configSection = document.getElementById('config-section');
  const convertSection = document.getElementById('convert-section');
  const outputFormat = document.getElementById('output-format');
  const qualitySlider = document.getElementById('quality-slider');
  const qualityValue = document.getElementById('quality-value');
  const qualitySection = document.getElementById('quality-section');
  const convertBtn = document.getElementById('convert-btn');
  const resultsSection = document.getElementById('results-section');
  const resultsList = document.getElementById('results-list');
  const wasmStatus = document.getElementById('wasm-status');
  const progressSection = document.getElementById('progress-section');
  const progressText = document.getElementById('progress-text');

  let files = [];
  let imageConverter = null;
  let convertedFiles = [];

  // Load WASM on page load
  async function loadWASM() {
    try {
      imageConverter = await getImageConverter();
      wasmStatus.textContent = 'WASM 模块加载成功！';
      wasmStatus.className = 'mb-4 p-4 rounded-comfortable bg-green-50 text-green-700 text-sm';
      setTimeout(() => {
        wasmStatus.style.display = 'none';
      }, 2000);
    } catch (error) {
      console.error('Failed to load WASM:', error);
      wasmStatus.textContent = 'WASM 模块加载失败，请刷新页面重试';
      wasmStatus.className = 'mb-4 p-4 rounded-comfortable bg-red-50 text-red-700 text-sm';
    }
  }

  loadWASM();

  // Upload zone events
  uploadZone?.addEventListener('click', () => fileInput?.click());
  
  uploadZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadZone.classList.add('border-vercel-black/40', 'bg-gray-50');
  });

  uploadZone?.addEventListener('dragleave', () => {
    uploadZone.classList.remove('border-vercel-black/40', 'bg-gray-50');
  });

  uploadZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('border-vercel-black/40', 'bg-gray-50');
    if (e.dataTransfer?.files) {
      handleFiles(Array.from(e.dataTransfer.files));
    }
  });

  fileInput?.addEventListener('change', () => {
    if (fileInput.files) {
      handleFiles(Array.from(fileInput.files));
    }
  });

  function handleFiles(newFiles) {
    files = [...files, ...newFiles];
    renderFileList();
    fileListSection?.classList.remove('hidden');
    configSection?.classList.remove('hidden');
    convertSection?.classList.remove('hidden');
    resultsSection?.classList.add('hidden');
  }

  function renderFileList() {
    if (!fileList) return;
    fileList.innerHTML = files.map((file, index) => `
      <div class="flex items-center justify-between p-4 rounded-standard bg-gray-50">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-standard bg-gray-200 flex items-center justify-center text-lg">
            🖼️
          </div>
          <div>
            <p class="font-medium text-vercel-black">${file.name}</p>
            <p class="text-sm text-gray-600">${(file.size / 1024 / 1024).toFixed(2)} MB</p>
          </div>
        </div>
        <button onclick="removeFile(${index})" class="p-2 text-gray-400 hover:text-red-500 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    `).join('');
  }

  window.removeFile = (index) => {
    files.splice(index, 1);
    renderFileList();
    if (files.length === 0) {
      fileListSection?.classList.add('hidden');
      configSection?.classList.add('hidden');
      convertSection?.classList.add('hidden');
      resultsSection?.classList.add('hidden');
    }
  };

  // Quality slider
  qualitySlider?.addEventListener('input', () => {
    if (qualityValue) qualityValue.textContent = qualitySlider.value;
  });

  // Show/hide quality based on format
  outputFormat?.addEventListener('change', () => {
    if (outputFormat.value === 'jpeg') {
      qualitySection?.classList.remove('hidden');
    } else {
      qualitySection?.classList.add('hidden');
    }
  });

  // Convert button with WASM
  convertBtn?.addEventListener('click', async () => {
    if (!imageConverter) {
      alert('WASM 模块尚未加载完成，请稍后再试');
      return;
    }

    convertBtn.disabled = true;
    convertBtn.textContent = '转换中...';
    progressSection?.classList.remove('hidden');
    
    convertedFiles = [];
    const totalFiles = files.length;

    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      const progress = Math.round((i / totalFiles) * 100);
      
      // Update progress
      const progressBar = document.getElementById('convert-progress');
      if (progressBar) {
        progressBar.setAttribute('progress', progress.toString());
      }
      if (progressText) {
        progressText.textContent = `正在转换 ${file.name}... (${i + 1}/${totalFiles})`;
      }

      try {
        // Read file as array buffer
        const arrayBuffer = await file.arrayBuffer();
        const inputData = new Uint8Array(arrayBuffer);

        // Get image info
        const info = await imageConverter.getImageInfo(inputData);
        console.log('Image info:', info);

        // Convert image
        const outputFormatValue = outputFormat.value;
        
        // Only use quality for JPEG format
        const quality = outputFormatValue === 'jpeg' ? parseInt(qualitySlider.value) : 100;
        
        const result = await imageConverter.convertImage(
          inputData,
          outputFormatValue,
          quality
        );

        if (result) {
          // Create blob and download URL
          const mimeTypes = {
            png: 'image/png',
            jpeg: 'image/jpeg',
            bmp: 'image/bmp',
            gif: 'image/gif'
          };
          
          const blob = new Blob([result], { type: mimeTypes[outputFormatValue] || 'image/png' });
          const url = URL.createObjectURL(blob);
          
          const newFileName = file.name.replace(/\.[^/.]+$/, '') + '.' + outputFormatValue;
          
          convertedFiles.push({
            originalName: file.name,
            newName: newFileName,
            url: url,
            size: blob.size
          });
        }
      } catch (error) {
        console.error('Conversion failed for', file.name, error);
        convertedFiles.push({
          originalName: file.name,
          error: true,
          errorMessage: error.message
        });
      }
    }

    // Show 100% progress
    const progressBar = document.getElementById('convert-progress');
    if (progressBar) {
      progressBar.setAttribute('progress', '100');
    }
    if (progressText) {
      progressText.textContent = '转换完成！';
    }

    // Show results
    showResults();

    // Update stats
    const stats = JSON.parse(localStorage.getItem('wizgo-stats') || '{"conversions": 0}');
    stats.conversions += convertedFiles.filter(f => !f.error).length;
    localStorage.setItem('wizgo-stats', JSON.stringify(stats));

    convertBtn.disabled = false;
    convertBtn.textContent = '开始转换';
  });

  function showResults() {
    resultsSection?.classList.remove('hidden');
    if (resultsList) {
      resultsList.innerHTML = convertedFiles.map(file => {
        if (file.error) {
          return `
            <div class="flex items-center justify-between p-4 rounded-standard bg-red-50 border border-red-200">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-standard bg-red-100 flex items-center justify-center">
                  <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-vercel-black">${file.originalName}</p>
                  <p class="text-sm text-red-600">转换失败: ${file.errorMessage}</p>
                </div>
              </div>
            </div>
          `;
        }
        
        return `
          <div class="flex items-center justify-between p-4 rounded-standard bg-green-50 border border-green-200">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-standard bg-green-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <p class="font-medium text-vercel-black">${file.newName}</p>
                <p class="text-sm text-green-600">转换成功 (${(file.size / 1024).toFixed(2)} KB)</p>
              </div>
            </div>
            <a href="${file.url}" download="${file.newName}" 
               class="px-4 py-2 bg-vercel-white text-vercel-black rounded-standard shadow-border hover:shadow-card transition-all text-sm font-medium">
              下载
            </a>
          </div>
        `;
      }).join('');
    }
  }
</script>
