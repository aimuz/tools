---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="Base64 编解码 - 在线文本/文件转换工具 | WizGo"
  description="免费在线 Base64 编解码工具，支持文本与 Base64 互转、文件上传转 Base64、Base64 下载为文件。图片、文本、二进制文件均可处理，浏览器本地处理不上传。"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Base64 编解码',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    description: '文本/文件与 Base64 互转工具，支持图片、文本、二进制文件',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: 'https://wizgo.xyz/base64',
  })} slot="head" />
  <Header />

  <main class="flex-1 py-10">
    <div class="max-w-[960px] mx-auto px-6">
      <!-- Title -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-semibold text-[#171717] mb-2">Base64 编解码</h1>
        <p class="text-gray-500">文本/文件与 Base64 互转 · 支持图片、文本、二进制文件 · 本地处理不上传</p>
      </div>

      <!-- Mode Switch -->
      <div class="flex justify-center mb-6">
        <div class="inline-flex p-1 bg-gray-100 rounded-lg">
          <button data-mode="encode" class="mode-btn px-4 py-2 text-sm rounded-md bg-white text-[#171717] shadow-sm transition-all">编码</button>
          <button data-mode="decode" class="mode-btn px-4 py-2 text-sm rounded-md text-gray-500 hover:text-[#171717] transition-all">解码</button>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Input Section -->
        <section>
          <div class="flex justify-between items-center mb-2">
            <span id="input-label" class="text-sm font-medium text-[#171717]">输入文本</span>
            <div class="flex gap-2">
              <button id="clear-btn" class="text-xs text-gray-400 hover:text-red-500">清空</button>
              <label class="text-xs text-gray-400 hover:text-[#171717] cursor-pointer">
                <input id="file-input" type="file" class="hidden" />
                <span>上传文件</span>
              </label>
            </div>
          </div>

          <!-- Text Input -->
          <textarea
            id="text-input"
            class="w-full h-64 p-4 bg-white border border-gray-200 rounded-lg font-mono text-sm focus:outline-none focus:border-[#171717] resize-none"
            placeholder="在此输入文本..."
          ></textarea>

          <!-- File Info (shown when file uploaded) -->
          <div id="file-info" class="hidden mt-3 p-3 bg-gray-50 border border-gray-200 rounded-lg">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <span id="file-name" class="text-sm text-[#171717] truncate max-w-[200px]"></span>
              </div>
              <span id="file-size" class="text-xs text-gray-400"></span>
            </div>
            <p id="file-type" class="text-xs text-gray-400 mt-1"></p>
          </div>

          <p class="text-xs text-gray-400 mt-2">文件大小限制：5MB</p>
        </section>

        <!-- Output Section -->
        <section>
          <div class="flex justify-between items-center mb-2">
            <span id="output-label" class="text-sm font-medium text-[#171717]">Base64 结果</span>
            <div class="flex gap-2">
              <button id="copy-btn" class="text-xs text-gray-400 hover:text-[#171717]">复制</button>
              <button id="download-btn" class="hidden text-xs text-gray-400 hover:text-[#171717]">下载文件</button>
            </div>
          </div>

          <!-- Text Output -->
          <textarea
            id="text-output"
            readonly
            class="w-full h-64 p-4 bg-gray-50 border border-gray-200 rounded-lg font-mono text-sm resize-none break-all"
            placeholder="结果将显示在这里..."
          ></textarea>

          <!-- Image Preview -->
          <div id="image-preview" class="hidden mt-3">
            <p class="text-xs text-gray-400 mb-2">图片预览</p>
            <div class="p-3 bg-gray-50 border border-gray-200 rounded-lg">
              <img id="preview-img" class="max-w-full max-h-48 mx-auto" alt="预览" />
            </div>
          </div>
        </section>
      </div>

      <!-- Error -->
      <div id="error-msg" class="hidden mt-5 p-3 bg-red-50 border border-red-100 rounded-lg text-red-500 text-sm"></div>

      <!-- Tips -->
      <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-xl">
        <h3 class="text-sm font-medium text-[#171717] mb-2">使用说明</h3>
        <ul class="text-xs text-gray-500 space-y-1 list-disc list-inside">
          <li>编码：输入任意文本或上传文件，自动转换为 Base64 字符串</li>
          <li>解码：粘贴 Base64 字符串（可包含 data URI 前缀），自动还原为文本或文件</li>
          <li>支持图片预览：解码后的图片可直接在页面中查看</li>
          <li>文件下载：解码后的二进制文件可直接下载保存</li>
        </ul>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

  // Elements
  const modeBtns = document.querySelectorAll<HTMLButtonElement>('.mode-btn');
  const textInput = $<HTMLTextAreaElement>('text-input');
  const textOutput = $<HTMLTextAreaElement>('text-output');
  const fileInput = $<HTMLInputElement>('file-input');
  const fileInfo = $('file-info');
  const fileName = $('file-name');
  const fileSize = $('file-size');
  const fileType = $('file-type');
  const imagePreview = $('image-preview');
  const previewImg = $<HTMLImageElement>('preview-img');
  const downloadBtn = $('download-btn');
  const errorMsg = $('error-msg');
  const inputLabel = $('input-label');
  const outputLabel = $('output-label');

  let mode: 'encode' | 'decode' = 'encode';
  let currentFile: File | null = null;
  let decodedBlob: Blob | null = null;
  let decodedFileName = '';

  const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB

  // Show error
  const showError = (msg: string) => {
    errorMsg.textContent = msg;
    errorMsg.classList.remove('hidden');
  };

  const hideError = () => {
    errorMsg.classList.add('hidden');
  };

  // Format file size
  const formatSize = (bytes: number) => {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  };

  // Set mode
  const setMode = (newMode: 'encode' | 'decode') => {
    mode = newMode;
    modeBtns.forEach(btn => {
      const isActive = btn.dataset.mode === mode;
      btn.classList.toggle('bg-white', isActive);
      btn.classList.toggle('text-[#171717]', isActive);
      btn.classList.toggle('shadow-sm', isActive);
      btn.classList.toggle('text-gray-500', !isActive);
    });

    // Update labels
    if (mode === 'encode') {
      inputLabel.textContent = '输入文本';
      outputLabel.textContent = 'Base64 结果';
      textInput.placeholder = '在此输入文本...';
      textOutput.placeholder = 'Base64 结果将显示在这里...';
    } else {
      inputLabel.textContent = '输入 Base64';
      outputLabel.textContent = '解码结果';
      textInput.placeholder = '在此输入 Base64 字符串...';
      textOutput.placeholder = '解码结果将显示在这里...';
    }

    // Clear states
    clearAll();
  };

  // Clear all
  const clearAll = () => {
    textInput.value = '';
    textOutput.value = '';
    fileInput.value = '';
    currentFile = null;
    decodedBlob = null;
    decodedFileName = '';
    fileInfo.classList.add('hidden');
    imagePreview.classList.add('hidden');
    downloadBtn.classList.add('hidden');
    hideError();
  };

  // Encode text to base64
  const encodeText = (text: string) => {
    try {
      const encoded = btoa(unescape(encodeURIComponent(text)));
      textOutput.value = encoded;
      downloadBtn.classList.add('hidden');
      imagePreview.classList.add('hidden');
      hideError();
    } catch (e) {
      showError('编码失败：文本包含无法处理的字符');
    }
  };

  // Encode file to base64
  const encodeFile = (file: File) => {
    const reader = new FileReader();
    reader.onload = () => {
      const result = reader.result as string;
      textOutput.value = result; // data:image/png;base64,... format
      hideError();

      // Show image preview if it's an image
      if (file.type.startsWith('image/')) {
        previewImg.src = result;
        imagePreview.classList.remove('hidden');
      }
    };
    reader.onerror = () => {
      showError('文件读取失败');
    };
    reader.readAsDataURL(file);
  };

  // Decode base64
  const decodeBase64 = (input: string) => {
    try {
      hideError();

      // Remove data URI prefix if present
      let base64String = input.trim();
      let mimeType = '';

      const dataUriMatch = base64String.match(/^data:([^;]+);base64,(.+)$/);
      if (dataUriMatch) {
        mimeType = dataUriMatch[1];
        base64String = dataUriMatch[2];
      }

      // Try to decode as text first
      try {
        const text = decodeURIComponent(escape(atob(base64String)));
        textOutput.value = text;
        downloadBtn.classList.add('hidden');
        imagePreview.classList.add('hidden');

        // If it looks like binary, also prepare blob for download
        if (mimeType) {
          const byteCharacters = atob(base64String);
          const byteNumbers = new Array(byteCharacters.length);
          for (let i = 0; i < byteCharacters.length; i++) {
            byteNumbers[i] = byteCharacters.charCodeAt(i);
          }
          const byteArray = new Uint8Array(byteNumbers);
          decodedBlob = new Blob([byteArray], { type: mimeType });
          decodedFileName = `decoded-file${getExtensionFromMime(mimeType)}`;
          downloadBtn.classList.remove('hidden');

          // Show image preview if it's an image
          if (mimeType.startsWith('image/')) {
            const url = URL.createObjectURL(decodedBlob);
            previewImg.src = url;
            imagePreview.classList.remove('hidden');
          }
        }
      } catch (e) {
        // Binary data - create blob
        const byteCharacters = atob(base64String);
        const byteNumbers = new Array(byteCharacters.length);
        for (let i = 0; i < byteCharacters.length; i++) {
          byteNumbers[i] = byteCharacters.charCodeAt(i);
        }
        const byteArray = new Uint8Array(byteNumbers);
        decodedBlob = new Blob([byteArray], { type: mimeType || 'application/octet-stream' });
        decodedFileName = `decoded-file${getExtensionFromMime(mimeType || 'application/octet-stream')}`;

        textOutput.value = `[二进制文件 - ${formatSize(decodedBlob.size)}]`;
        downloadBtn.classList.remove('hidden');

        // Show image preview if it's an image
        if ((mimeType || '').startsWith('image/')) {
          const url = URL.createObjectURL(decodedBlob);
          previewImg.src = url;
          imagePreview.classList.remove('hidden');
        } else {
          imagePreview.classList.add('hidden');
        }
      }
    } catch (e) {
      showError('解码失败：无效的 Base64 字符串');
    }
  };

  // Get file extension from MIME type
  const getExtensionFromMime = (mime: string) => {
    const extensions: Record<string, string> = {
      'image/png': '.png',
      'image/jpeg': '.jpg',
      'image/jpg': '.jpg',
      'image/gif': '.gif',
      'image/webp': '.webp',
      'image/svg+xml': '.svg',
      'text/plain': '.txt',
      'text/html': '.html',
      'text/css': '.css',
      'text/javascript': '.js',
      'application/json': '.json',
      'application/pdf': '.pdf',
      'application/zip': '.zip',
    };
    return extensions[mime] || '';
  };

  // Event listeners
  modeBtns.forEach(btn => {
    btn.addEventListener('click', () => setMode(btn.dataset.mode as 'encode' | 'decode'));
  });

  textInput.addEventListener('input', () => {
    hideError();
    if (mode === 'encode') {
      if (!currentFile) {
        encodeText(textInput.value);
      }
    } else {
      decodeBase64(textInput.value);
    }
  });

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (!file) return;

    if (file.size > MAX_FILE_SIZE) {
      showError(`文件过大，最大支持 5MB，当前 ${formatSize(file.size)}`);
      return;
    }

    currentFile = file;
    fileName.textContent = file.name;
    fileSize.textContent = formatSize(file.size);
    fileType.textContent = file.type || '未知类型';
    fileInfo.classList.remove('hidden');

    // Clear text input and encode file
    textInput.value = '';
    if (mode === 'encode') {
      encodeFile(file);
    }
  });

  $('clear-btn').addEventListener('click', clearAll);

  $('copy-btn').addEventListener('click', async () => {
    if (!textOutput.value) return;
    try {
      await navigator.clipboard.writeText(textOutput.value);
      const btn = $('copy-btn');
      const old = btn.textContent;
      btn.textContent = '已复制';
      setTimeout(() => btn.textContent = old, 1200);
    } catch {}
  });

  downloadBtn.addEventListener('click', () => {
    if (!decodedBlob) return;
    const url = URL.createObjectURL(decodedBlob);
    const a = document.createElement('a');
    a.href = url;
    a.download = decodedFileName;
    a.click();
    URL.revokeObjectURL(url);
  });

  // Init
  setMode('encode');
</script>
