---
interface Props {
  href: string;
  icon: string;
  title: string;
  description: string;
}

const { href, icon, title, description } = Astro.props;
---

<a 
  href={href}
  class="group block p-8 rounded-comfortable bg-vercel-white shadow-border
         hover:shadow-card transition-all duration-200"
>
  <div class="w-12 h-12 rounded-comfortable bg-gray-50 flex items-center justify-center mb-4
              group-hover:bg-develop-blue/10 transition-colors">
    <span class="text-2xl">{icon}</span>
  </div>
  <h3 class="text-2xl font-semibold text-vercel-black tracking-tight-0.96 mb-2">
    {title}
  </h3>
  <p class="text-gray-600 leading-body">{description}</p>
  <div class="mt-4 flex items-center text-sm font-medium text-vercel-black">
    开始使用
    <svg 
      class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" 
      fill="none" 
      stroke="currentColor" 
      viewBox="0 0 24 24"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
    </svg>
  </div>
</a>
