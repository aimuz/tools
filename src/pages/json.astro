---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="JSON 格式化 - 在线美化、压缩、校验工具 | WizGo"
  description="免费在线 JSON 格式化工具，支持 JSON 美化、压缩、语法校验，一键复制。纯浏览器本地处理，粘贴的数据不会上传到任何服务器。"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'JSON 格式化',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    description: 'JSON 美化、压缩、校验工具，本地处理不上传',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: 'https://wizgo.xyz/json',
  })} slot="head" />
  <Header />

  <main class="flex-1 py-12">
    <div class="max-w-[960px] mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-semibold text-[#171717] mb-2">JSON 格式化</h1>
        <p class="text-gray-500">JSON 美化、压缩、语法校验 · 本地处理不上传</p>
      </div>

      <!-- Input -->
      <div class="mb-4">
        <div class="flex justify-between items-center mb-2">
          <span class="text-sm text-gray-500">输入 JSON</span>
          <div class="flex gap-2">
            <button id="format-btn" class="px-3 py-1.5 text-sm bg-[#171717] text-white rounded hover:bg-gray-800">美化</button>
            <button id="minify-btn" class="px-3 py-1.5 text-sm border border-gray-200 text-gray-600 rounded hover:border-[#171717]">压缩</button>
            <button id="clear-btn" class="px-3 py-1.5 text-sm text-gray-400 hover:text-red-500">清空</button>
          </div>
        </div>
        <textarea
          id="json-input"
          class="w-full h-64 p-4 bg-white border border-gray-200 rounded-lg font-mono text-sm focus:outline-none focus:border-[#171717] resize-none"
          placeholder='{"example": "在此输入 JSON 数据"}'
        ></textarea>
      </div>

      <!-- Output -->
      <div>
        <div class="flex justify-between items-center mb-2">
          <span class="text-sm text-gray-500">结果</span>
          <button id="copy-btn" class="text-sm text-gray-400 hover:text-[#171717]">复制</button>
        </div>
        <textarea
          id="json-output"
          readonly
          class="w-full h-64 p-4 bg-gray-50 border border-gray-200 rounded-lg font-mono text-sm resize-none"
          placeholder="格式化后的 JSON 将显示在这里"
        ></textarea>
      </div>

      <!-- Error -->
      <div id="error-msg" class="hidden mt-4 p-3 bg-red-50 border border-red-100 rounded-lg text-red-500 text-sm"></div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const input = document.getElementById('json-input') as HTMLTextAreaElement;
  const output = document.getElementById('json-output') as HTMLTextAreaElement;
  const formatBtn = document.getElementById('format-btn');
  const minifyBtn = document.getElementById('minify-btn');
  const clearBtn = document.getElementById('clear-btn');
  const copyBtn = document.getElementById('copy-btn');
  const errorMsg = document.getElementById('error-msg');

  function showError(msg: string) {
    if (errorMsg) {
      errorMsg.textContent = msg;
      errorMsg.classList.remove('hidden');
    }
  }

  function hideError() {
    if (errorMsg) {
      errorMsg.classList.add('hidden');
    }
  }

  formatBtn?.addEventListener('click', () => {
    try {
      const value = input?.value.trim();
      if (!value) return;
      
      const parsed = JSON.parse(value);
      if (output) {
        output.value = JSON.stringify(parsed, null, 2);
      }
      hideError();
    } catch (e) {
      showError('JSON 格式错误，请检查输入');
    }
  });

  minifyBtn?.addEventListener('click', () => {
    try {
      const value = input?.value.trim();
      if (!value) return;
      
      const parsed = JSON.parse(value);
      if (output) {
        output.value = JSON.stringify(parsed);
      }
      hideError();
    } catch (e) {
      showError('JSON 格式错误，请检查输入');
    }
  });

  clearBtn?.addEventListener('click', () => {
    if (input) input.value = '';
    if (output) output.value = '';
    hideError();
  });

  copyBtn?.addEventListener('click', () => {
    if (output?.value) {
      navigator.clipboard.writeText(output.value);
      const original = copyBtn.textContent;
      copyBtn.textContent = '已复制';
      setTimeout(() => {
        copyBtn.textContent = original;
      }, 1500);
    }
  });
</script>
