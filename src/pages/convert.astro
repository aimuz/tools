---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="图片格式转换 - PNG JPG WebP HEIC 在线互转 | WizGo"
  description="免费在线图片格式转换工具，支持 PNG、JPG、JPEG、WebP、GIF、BMP 等常见格式互转。纯浏览器本地处理不上传，安全快速无需安装。"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: '图片格式转换',
    applicationCategory: 'MultimediaApplication',
    operatingSystem: 'Any',
    description: 'PNG、JPG、WebP、GIF、BMP 在线互转，本地处理不上传',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: 'https://wizgo.xyz/convert',
  })} slot="head" />
  <Header />

  <main class="flex-1 py-12">
    <div class="max-w-[720px] mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-semibold text-[#171717] mb-2">图片格式转换</h1>
        <p class="text-gray-500">PNG、JPG、WebP、GIF、BMP 在线互转 · 本地处理不上传</p>
      </div>

      <!-- Upload Area -->
      <div
        id="upload-zone"
        class="relative w-full min-h-[200px] rounded-xl border-2 border-dashed border-gray-300 hover:border-[#171717] transition-colors bg-white flex flex-col items-center justify-center gap-3 cursor-pointer mb-6"
      >
      <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
      </svg>
        <div class="text-center">
          <p class="text-base text-[#171717]">拖放图片到此处</p>
          <p class="text-sm text-gray-400 mt-1">或点击上传</p>
        </div>
        <p class="text-xs text-gray-400">最大 100MB</p>
        <input type="file" id="file-input" class="hidden" accept="image/*" multiple />
      </div>

      <!-- Options -->
      <div id="options" class="mb-6 hidden">
        <!-- From Format (Auto detect) -->
        <div class="mb-4">
          <p class="text-sm text-gray-500 mb-2">原格式：<span id="detected-format" class="text-[#171717] font-medium">自动检测</span></p>
        </div>

        <!-- To Format -->
        <div class="mb-4">
          <p class="text-sm text-gray-500 mb-2">转换为：</p>
          <div class="flex flex-wrap gap-2" id="format-buttons">
            <button class="format-btn px-4 py-2 text-sm rounded-lg border border-gray-200 bg-[#171717] text-white" data-format="jpg">JPG</button>
            <button class="format-btn px-4 py-2 text-sm rounded-lg border border-gray-200 text-gray-600 hover:border-[#171717]" data-format="png">PNG</button>
            <button class="format-btn px-4 py-2 text-sm rounded-lg border border-gray-200 text-gray-600 hover:border-[#171717]" data-format="webp">WebP</button>
            <button class="format-btn px-4 py-2 text-sm rounded-lg border border-gray-200 text-gray-600 hover:border-[#171717]" data-format="bmp">BMP</button>
          </div>
        </div>

        <!-- Quality (only for JPG) -->
        <div id="quality-option" class="mb-6">
          <p class="text-sm text-gray-500 mb-2">画质：</p>
          <div class="flex gap-2">
            <button class="quality-btn px-4 py-2 text-sm rounded-full border border-gray-200 bg-[#171717] text-white" data-quality="90">高</button>
            <button class="quality-btn px-4 py-2 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]" data-quality="75">中</button>
            <button class="quality-btn px-4 py-2 text-sm rounded-full border border-gray-200 text-gray-600 hover:border-[#171717]" data-quality="60">低</button>
          </div>
        </div>

        <button id="convert-btn" class="w-full py-3 bg-[#171717] text-white rounded-lg font-medium hover:bg-gray-800 transition-colors">
          开始转换
        </button>
      </div>

      <!-- File List -->
      <div id="file-list" class="space-y-3 mb-6"></div>

      <!-- Results -->
      <div id="results" class="space-y-3 hidden"></div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { initConvertPage } from '../scripts/convert-page';
  initConvertPage({ readUrlParams: true, defaultTo: 'jpg' });
</script>
