---
interface Tool {
  href: string;
  icon: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  href?: string;
  tools: Tool[];
}

const { title, href, tools } = Astro.props;
---

<section class="mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-[#171717]">{title}</h2>
    {href && (
      <a href={href} class="text-sm text-gray-500 hover:text-[#171717] transition-colors">
        查看全部 →
      </a>
    )}
  </div>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {tools.map((tool) => (
      <div data-tool-card data-tool-title={tool.title.toLowerCase()} data-tool-desc={tool.description.toLowerCase()}>
        <a
          href={tool.href}
          class="group block p-5 bg-white border border-gray-200 rounded-lg hover:border-[#171717] hover:shadow-sm transition-all duration-200 h-full"
        >
          <div class="w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center mb-3 group-hover:bg-gray-100 transition-colors">
            <span class="text-xl">{tool.icon}</span>
          </div>
          <h3 class="text-base font-semibold text-[#171717] mb-1">
            {tool.title}
          </h3>
          <p class="text-sm text-gray-500 line-clamp-2">{tool.description}</p>
        </a>
      </div>
    ))}
  </div>
</section>
