---
import Layout from '../../layouts/Layout.astro';
import Header from '../layout/Header.astro';
import Footer from '../layout/Footer.astro';
import { useTranslations } from '../../i18n';
import type { Locale } from '../../i18n/config';
import { absoluteUrl } from '../../i18n/seo';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const p = t.pages.password;
const pageUrl = absoluteUrl(locale, '/password');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: p.schema.name,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  description: p.schema.description,
  inLanguage: locale,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  url: pageUrl,
};
---

<Layout title={p.title} description={p.description} locale={locale}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
    slot="head"
  />
  <Header locale={locale} />

  <main class="flex-1 py-10">
    <div class="max-w-[800px] mx-auto px-6">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-semibold text-[#171717] mb-2">{p.h1}</h1>
        <p class="text-gray-500">{p.subheading}</p>
      </div>

      <section class="mb-6">
        <div class="space-y-5">
          {/* Password Type Toggle */}
          <div class="flex justify-center">
            <div class="inline-flex p-1 bg-gray-100 rounded-lg">
              <button
                type="button"
                data-mode="random"
                class="mode-btn px-4 py-2 text-sm rounded-md bg-white text-[#171717] shadow-sm transition-all"
              >
                {p.mode.random}
              </button>
              <button
                type="button"
                data-mode="passphrase"
                class="mode-btn px-4 py-2 text-sm rounded-md text-gray-500 hover:text-[#171717] transition-all"
              >
                {p.mode.passphrase}
              </button>
            </div>
          </div>

          {/* Random Password Options */}
          <div id="random-options">
            <div>
              <div class="flex items-center justify-between mb-3">
                <label class="text-sm text-gray-500">{p.lengthLabel}</label>
                <span
                  id="length-display"
                  class="text-sm font-medium text-[#171717]">16</span
                >
              </div>
              <input
                type="range"
                id="length-slider"
                min="4"
                max="64"
                value="16"
                class="w-full accent-[#171717]"
              />
              <div class="flex justify-between text-xs text-gray-400 mt-1">
                <span>4</span>
                <span>32</span>
                <span>64</span>
              </div>
            </div>

            <div class="mt-5">
              <label class="block text-sm text-gray-500 mb-3"
                >{p.charTypesLabel}</label
              >
              <div class="grid grid-cols-2 gap-3">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    id="uppercase"
                    checked
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600"
                    >{p.charTypes.uppercase}</span
                  >
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    id="lowercase"
                    checked
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600"
                    >{p.charTypes.lowercase}</span
                  >
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    id="numbers"
                    checked
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600"
                    >{p.charTypes.numbers}</span
                  >
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    id="symbols"
                    checked
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600"
                    >{p.charTypes.symbols}</span
                  >
                </label>
              </div>
            </div>

            <div class="mt-5">
              <label class="block text-sm text-gray-500 mb-3"
                >{p.advanced.label}</label
              >
              <div class="space-y-2">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    id="exclude-similar"
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600"
                    >{p.advanced.excludeSimilar}</span
                  >
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    id="exclude-ambiguous"
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600"
                    >{p.advanced.excludeAmbiguous}</span
                  >
                </label>
              </div>
            </div>
          </div>

          {/* Passphrase Options */}
          <div id="passphrase-options" class="hidden">
            <div>
              <div class="flex items-center justify-between mb-3">
                <label class="text-sm text-gray-500">{p.wordCountLabel}</label>
                <span
                  id="word-count-display"
                  class="text-sm font-medium text-[#171717]">4</span
                >
              </div>
              <input
                type="range"
                id="word-count-slider"
                min="3"
                max="8"
                value="4"
                class="w-full accent-[#171717]"
              />
              <div class="flex justify-between text-xs text-gray-400 mt-1">
                <span>3</span>
                <span>5</span>
                <span>8</span>
              </div>
            </div>

            <div class="mt-5">
              <label class="block text-sm text-gray-500 mb-3"
                >{p.separatorLabel}</label
              >
              <div class="grid grid-cols-2 gap-2">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    name="separator"
                    value="-"
                    checked
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600"
                    >{p.separators.hyphen}</span
                  >
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    name="separator"
                    value="_"
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600"
                    >{p.separators.underscore}</span
                  >
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    name="separator"
                    value=" "
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600">{p.separators.space}</span
                  >
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    name="separator"
                    value="."
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600"
                    >{p.separators.period}</span
                  >
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="radio"
                    name="separator"
                    value="number"
                    class="accent-[#171717]"
                  />
                  <span class="text-sm text-gray-600"
                    >{p.separators.number}</span
                  >
                </label>
              </div>
            </div>
          </div>

          <button
            id="generate-btn"
            class="w-full px-4 py-2.5 bg-[#171717] text-white text-sm rounded-lg hover:bg-gray-800 transition-colors"
          >
            {p.generateBtn}
          </button>
        </div>
      </section>

      <section class="mb-6">
        <div class="flex justify-between items-center mb-3">
          <span class="text-sm text-gray-500">{p.resultLabel}</span>
          <div class="flex items-center gap-2">
            <span
              id="strength-label"
              class="text-xs text-gray-400"
              data-i18n-label={p.strength.label}
              data-i18n-weak={p.strength.weak}
              data-i18n-fair={p.strength.fair}
              data-i18n-good={p.strength.good}
              data-i18n-strong={p.strength.strong}
              >{p.strength.label}: <span id="strength-value">-</span></span
            >
          </div>
        </div>

        <div class="relative">
          <div
            id="password-result"
            class="w-full p-4 pr-24 bg-white border border-gray-200 rounded-lg font-mono text-lg text-[#171717] break-all min-h-[60px] flex items-center"
          >
            <span class="text-gray-400">················</span>
          </div>
          <div class="absolute right-2 top-1/2 -translate-y-1/2 flex gap-2">
            <button
              id="copy-btn"
              class="px-3 py-1.5 text-xs border border-gray-200 rounded-md text-gray-600 hover:border-[#171717] hover:text-[#171717] transition-colors"
              data-default={p.copyBtn}
              data-copied={p.copiedBtn}
            >
              {p.copyBtn}
            </button>
          </div>
        </div>

        <div class="mt-3 h-1.5 bg-gray-100 rounded-full overflow-hidden">
          <div id="strength-bar" class="h-full w-0 transition-all duration-300">
          </div>
        </div>
      </section>

      <div class="mt-8 p-4 bg-gray-50 border border-gray-200 rounded-xl">
        <h3 class="text-sm font-medium text-[#171717] mb-2">
          {p.info.heading}
        </h3>
        <p class="text-xs text-gray-500 leading-relaxed">{p.info.body}</p>
      </div>
    </div>
  </main>

  <Footer locale={locale} />

  <script>
    import { COMMON_WORDS } from '../../data/word';
    const $ = <T extends HTMLElement = HTMLElement>(id: string) =>
      document.getElementById(id) as T;

    // Mode toggle
    const modeBtns = document.querySelectorAll<HTMLButtonElement>('.mode-btn');
    const randomOptions = $('random-options');
    const passphraseOptions = $('passphrase-options');

    // Random password controls
    const lengthSlider = $<HTMLInputElement>('length-slider');
    const lengthDisplay = $('length-display');
    const uppercaseCheckbox = $<HTMLInputElement>('uppercase');
    const lowercaseCheckbox = $<HTMLInputElement>('lowercase');
    const numbersCheckbox = $<HTMLInputElement>('numbers');
    const symbolsCheckbox = $<HTMLInputElement>('symbols');
    const excludeSimilarCheckbox = $<HTMLInputElement>('exclude-similar');
    const excludeAmbiguousCheckbox = $<HTMLInputElement>('exclude-ambiguous');

    // Passphrase controls
    const wordCountSlider = $<HTMLInputElement>('word-count-slider');
    const wordCountDisplay = $('word-count-display');

    const generateBtn = $('generate-btn');
    const passwordResult = $('password-result');
    const copyBtn = $('copy-btn');
    const strengthValue = $('strength-value');
    const strengthBar = $('strength-bar');

    const COPY_LABEL = copyBtn?.dataset.default ?? 'Copy';
    const COPIED_LABEL = copyBtn?.dataset.copied ?? 'Copied';

    let currentMode: 'random' | 'passphrase' = 'random';

    // Unbiased random integer in [0, max) using rejection sampling over a
    // Uint32 space. Plain `rand() % max` skews the distribution when `max`
    // doesn't divide 2^32 — unacceptable for secret generation.
    const secureRandomInt = (max: number): number => {
      if (max <= 0) return 0;
      const cutoff = Math.floor(0x100000000 / max) * max;
      const buf = new Uint32Array(1);
      while (true) {
        crypto.getRandomValues(buf);
        if (buf[0] < cutoff) return buf[0] % max;
      }
    };

    const pickChar = (chars: string): string =>
      chars[secureRandomInt(chars.length)];

    const CHAR_SETS = {
      uppercase: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      lowercase: 'abcdefghijklmnopqrstuvwxyz',
      numbers: '0123456789',
      symbols: '!@#$%^&*()_+-=[]{}|;:,.<>?',
    };

    const SIMILAR_CHARS = 'il1Lo0O';
    const AMBIGUOUS_SYMBOLS = '{}[]()/\\\'"`~,;:.<>';

    const strengthLabelEl = $('strength-label');
    const STRENGTH_LABELS = [
      strengthLabelEl.dataset.i18nWeak ?? 'Weak',
      strengthLabelEl.dataset.i18nFair ?? 'Fair',
      strengthLabelEl.dataset.i18nGood ?? 'Good',
      strengthLabelEl.dataset.i18nStrong ?? 'Strong',
    ];

    const getStrengthLabel = (
      strength: number,
    ): { text: string; color: string; width: string } => {
      if (strength === 0)
        return { text: STRENGTH_LABELS[0], color: 'bg-red-500', width: '25%' };
      if (strength === 1)
        return {
          text: STRENGTH_LABELS[1],
          color: 'bg-yellow-500',
          width: '50%',
        };
      if (strength === 2)
        return { text: STRENGTH_LABELS[2], color: 'bg-blue-500', width: '75%' };
      return { text: STRENGTH_LABELS[3], color: 'bg-green-500', width: '100%' };
    };

    // 计算单词数量（用于短语密码）
    const countWords = (passphrase: string): number => {
      // 检测分隔符类型
      if (passphrase.includes('-')) return passphrase.split('-').length;
      if (passphrase.includes('_')) return passphrase.split('_').length;
      if (passphrase.includes('.')) return passphrase.split('.').length;
      if (passphrase.includes(' ')) return passphrase.split(' ').length;
      // 数字分隔符或无分隔符（连续单词）
      return passphrase.replace(/[0-9]/g, ' ').trim().split(/\s+/).length;
    };

    const calculateStrength = (password: string): number => {
      const len = password.length;

      // 短语密码检测：是否主要由小写字母和分隔符组成
      const isPassphrase =
        /^[a-z\s\-_\.0-9]+$/.test(password) && password.length > 15;

      if (isPassphrase) {
        const wordCount = countWords(password);
        // 短语密码基于单词数量判断
        if (wordCount >= 6) return 3; // 强
        if (wordCount >= 4) return 2; // 良好
        if (wordCount >= 3) return 1; // 一般
        return 0; // 弱
      }

      // 随机密码强度判断
      const hasLower = /[a-z]/.test(password);
      const hasUpper = /[A-Z]/.test(password);
      const hasNumber = /[0-9]/.test(password);
      const hasSymbol = /[^a-zA-Z0-9]/.test(password);
      const charTypes = [hasLower, hasUpper, hasNumber, hasSymbol].filter(
        Boolean,
      ).length;

      // 太短: < 8位
      if (len < 8) return charTypes >= 3 ? 1 : 0;

      // 短密码: 8-11位
      if (len < 12) {
        if (charTypes === 4) return 2; // 良好
        if (charTypes >= 2) return 1; // 一般
        return 0; // 弱
      }

      // 中等长度: 12-15位
      if (len < 16) {
        if (charTypes === 4) return 3; // 强
        if (charTypes === 3) return 2; // 良好
        if (charTypes >= 2) return 1; // 一般
        return 0; // 弱
      }

      // 长密码: 16位+
      if (charTypes >= 3) return 3; // 强
      if (charTypes === 2) return 2; // 良好
      return 1; // 一般
    };

    const getFilteredCharset = (
      charset: string,
      excludeSimilar: boolean,
      excludeAmbiguous: boolean,
    ): string => {
      let result = charset;
      if (excludeSimilar) {
        for (const char of SIMILAR_CHARS) {
          result = result.replaceAll(char, '');
        }
      }
      if (excludeAmbiguous) {
        for (const char of AMBIGUOUS_SYMBOLS) {
          result = result.replaceAll(char, '');
        }
      }
      // 如果过滤后为空，回退到原始字符集
      return result.length > 0 ? result : charset;
    };

    const generatePassword = (): string => {
      const length = parseInt(lengthSlider.value, 10);
      const useUppercase = uppercaseCheckbox.checked;
      const useLowercase = lowercaseCheckbox.checked;
      const useNumbers = numbersCheckbox.checked;
      const useSymbols = symbolsCheckbox.checked;
      const excludeSimilar = excludeSimilarCheckbox.checked;
      const excludeAmbiguous = excludeAmbiguousCheckbox.checked;

      // 获取各类型的字符集
      const upperChars = useUppercase
        ? getFilteredCharset(CHAR_SETS.uppercase, excludeSimilar, false)
        : '';
      const lowerChars = useLowercase
        ? getFilteredCharset(CHAR_SETS.lowercase, excludeSimilar, false)
        : '';
      const numberChars = useNumbers
        ? getFilteredCharset(CHAR_SETS.numbers, excludeSimilar, false)
        : '';
      const symbolChars = useSymbols
        ? getFilteredCharset(CHAR_SETS.symbols, false, excludeAmbiguous)
        : '';

      // 确保至少有一种字符类型
      const requiredChars: string[] = [];
      if (upperChars) requiredChars.push(upperChars);
      if (lowerChars) requiredChars.push(lowerChars);
      if (numberChars) requiredChars.push(numberChars);
      if (symbolChars) requiredChars.push(symbolChars);

      if (requiredChars.length === 0) {
        // 默认使用小写+数字
        requiredChars.push(CHAR_SETS.lowercase, CHAR_SETS.numbers);
      }

      // 合并所有可用字符
      const allChars = requiredChars.join('');

      // 每种类型至少选一个，剩余随机填充
      const chars: string[] = [];
      for (const set of requiredChars) chars.push(pickChar(set));
      while (chars.length < length) chars.push(pickChar(allChars));

      // Fisher-Yates 洗牌，消除类型位置偏置
      for (let i = chars.length - 1; i > 0; i--) {
        const j = secureRandomInt(i + 1);
        [chars[i], chars[j]] = [chars[j], chars[i]];
      }
      return chars.join('');
    };

    const updateStrength = (password: string) => {
      const strength = calculateStrength(password);
      const { text, color, width } = getStrengthLabel(strength);
      strengthValue.textContent = text;
      strengthBar.className = `h-full transition-all duration-300 ${color}`;
      strengthBar.style.width = width;
    };

    // Mode switching
    const setMode = (mode: 'random' | 'passphrase') => {
      currentMode = mode;
      modeBtns.forEach((btn) => {
        const isActive = btn.dataset.mode === mode;
        if (isActive) {
          btn.classList.add('bg-white', 'text-[#171717]', 'shadow-sm');
          btn.classList.remove('text-gray-500');
        } else {
          btn.classList.remove('bg-white', 'text-[#171717]', 'shadow-sm');
          btn.classList.add('text-gray-500');
        }
      });

      if (mode === 'random') {
        randomOptions.classList.remove('hidden');
        passphraseOptions.classList.add('hidden');
      } else {
        randomOptions.classList.add('hidden');
        passphraseOptions.classList.remove('hidden');
      }
      generateAndDisplay();
    };

    modeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.mode as 'random' | 'passphrase';
        setMode(mode);
      });
    });

    // Generate passphrase
    const generatePassphrase = (): string => {
      const wordCount = parseInt(wordCountSlider.value, 10);
      const separatorRadio = document.querySelector<HTMLInputElement>(
        'input[name="separator"]:checked',
      );
      const separator = separatorRadio?.value ?? '-';

      const words = Array.from(
        { length: wordCount },
        () => COMMON_WORDS[secureRandomInt(COMMON_WORDS.length)],
      );

      if (separator === 'number') {
        const nums = secureRandomInt(90) + 10; // 10-99
        return words.join(String(nums));
      }
      return words.join(separator);
    };

    const generateAndDisplay = () => {
      const password =
        currentMode === 'random' ? generatePassword() : generatePassphrase();
      passwordResult.textContent = password;
      passwordResult.classList.remove('text-gray-400');
      passwordResult.classList.add('text-[#171717]');
      updateStrength(password);
    };

    lengthSlider.addEventListener('input', () => {
      lengthDisplay.textContent = lengthSlider.value;
      generateAndDisplay();
    });

    wordCountSlider.addEventListener('input', () => {
      wordCountDisplay.textContent = wordCountSlider.value;
      generateAndDisplay();
    });

    uppercaseCheckbox.addEventListener('change', generateAndDisplay);
    lowercaseCheckbox.addEventListener('change', generateAndDisplay);
    numbersCheckbox.addEventListener('change', generateAndDisplay);
    symbolsCheckbox.addEventListener('change', generateAndDisplay);
    excludeSimilarCheckbox.addEventListener('change', generateAndDisplay);
    excludeAmbiguousCheckbox.addEventListener('change', generateAndDisplay);

    document
      .querySelectorAll<HTMLInputElement>('input[name="separator"]')
      .forEach((radio) => {
        radio.addEventListener('change', generateAndDisplay);
      });

    generateBtn.addEventListener('click', generateAndDisplay);

    copyBtn.addEventListener('click', async () => {
      const password = passwordResult.textContent;
      if (!password || password.includes('·')) return;
      try {
        await navigator.clipboard.writeText(password);
        copyBtn.textContent = COPIED_LABEL;
        copyBtn.classList.add('text-green-600', 'border-green-600');
        setTimeout(() => {
          copyBtn.textContent = COPY_LABEL;
          copyBtn.classList.remove('text-green-600', 'border-green-600');
        }, 1200);
      } catch {}
    });

    generateAndDisplay();
  </script>
</Layout>
