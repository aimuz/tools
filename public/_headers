# Global security defaults — applied to every response.
# Link headers (RFC 8288 / RFC 9727) advertise agent-discoverable resources:
#   describedby → /llms.txt         (site description for LLM agents)
#   service-doc → /llms-full.txt    (full tool catalog)
#   sitemap     → /sitemap-index.xml
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
  X-Frame-Options: SAMEORIGIN
  Link: </llms.txt>; rel="describedby"; type="text/markdown"
  Link: </llms-full.txt>; rel="service-doc"; type="text/markdown"
  Link: </sitemap-index.xml>; rel="sitemap"; type="application/xml"

# Astro hashed build artefacts are content-addressed — safe to cache forever.
# Includes the Rust WASM modules: workers import them via `?url`, so Vite
# emits them into /_astro/ with a content hash.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fallback long-cache for any raw .woff2 (fonts are normally bundled into /_astro/).
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

# Agent Skills Discovery (https://agentskills.io, RFC v0.2.0)
/.well-known/agent-skills/index.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=300
/.well-known/agent-skills/wizgo-tools/SKILL.md
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=300

/sitemap-index.xml
  Cache-Control: public, max-age=3600

/sitemap-0.xml
  Cache-Control: public, max-age=3600

# Service worker must revalidate so new releases propagate.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/workbox-*.js
  Cache-Control: public, max-age=31536000, immutable
