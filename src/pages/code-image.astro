---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="代码转图片 - 精美代码分享图生成器 | WizGo"
  description="在线把代码片段转成精美分享图，支持 JavaScript、TypeScript、Python、Go、Rust 等多种语言，多种主题可选，一键下载 PNG。"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: '代码转图片',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    description: '把代码转成精美分享图，支持多语言和多主题',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    url: 'https://wizgo.xyz/code-image',
  })} slot="head" />
  <Header />

  <main class="flex-1 py-8">
    <div class="max-w-[900px] mx-auto px-6">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-semibold text-[#171717] mb-2">代码转图片</h1>
        <p class="text-gray-500">把代码片段生成精美分享图 · 多语言 · 多主题</p>
      </div>

      <!-- Controls -->
      <div class="flex flex-wrap gap-3 mb-6">
        <select id="language-select" class="px-3 py-2 bg-white border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-[#171717]">
          <option value="javascript">JavaScript</option>
          <option value="typescript">TypeScript</option>
          <option value="python">Python</option>
          <option value="java">Java</option>
          <option value="go">Go</option>
          <option value="rust">Rust</option>
          <option value="css">CSS</option>
          <option value="html">HTML</option>
          <option value="json">JSON</option>
          <option value="sql">SQL</option>
          <option value="bash">Bash</option>
        </select>

        <select id="theme-select" class="px-3 py-2 bg-white border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-[#171717]">
          <option value="onedark">One Dark</option>
          <option value="dracula">Dracula</option>
          <option value="github">GitHub</option>
        </select>

        <button id="format-btn" class="px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:border-[#171717] hover:text-[#171717] transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
          格式化
        </button>

        <button id="sample-btn" class="px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:border-[#171717] hover:text-[#171717] transition-colors">
          加载示例
        </button>

        <button id="copy-btn" class="ml-auto px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-600 hover:border-[#171717] hover:text-[#171717] transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
          </svg>
          复制图片
        </button>

        <button id="download-btn" class="px-4 py-2 bg-[#171717] text-white rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
          </svg>
          下载图片
        </button>
      </div>

      <!-- Code Window -->
      <div id="editor-container" class="rounded-xl overflow-hidden shadow-2xl">
        <!-- Window Header -->
        <div class="flex items-center justify-between px-4 py-3 bg-[#21252b] border-b border-[#3e4451]">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
          </div>
          <span id="filename" class="text-sm text-[#9da5b4] font-mono">main.js</span>
          <div class="w-16"></div>
        </div>

        <!-- Editor Body -->
        <div id="editor-body" class="relative bg-[#282c34]">
          <!-- Hidden textarea for input -->
          <textarea
            id="code-input"
            class="block w-full resize-none focus:outline-none z-20 overflow-hidden bg-transparent relative"
            style="color: transparent; caret-color: #abb2bf; padding: 20px 24px; font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Fira Code', Consolas, monospace; font-size: 14px; line-height: 1.6; white-space: pre; tab-size: 2; min-height: 320px; field-sizing: content;"
            placeholder="在此输入或粘贴代码..."
            spellcheck="false"
            rows="1"
          ></textarea>

          <!-- Visible highlight layer -->
          <pre
            id="highlight-layer"
            class="absolute inset-0 w-full m-0 pointer-events-none overflow-hidden z-10 bg-transparent"
            style="padding: 20px 24px; font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Fira Code', Consolas, monospace; font-size: 14px; line-height: 1.6; white-space: pre; tab-size: 2;"
          ></pre>
        </div>
      </div>

      <!-- Tips -->
      <div class="mt-6 p-4 bg-gray-50 rounded-lg">
        <p class="text-sm text-gray-500">
          <span class="font-medium text-[#171717]">提示：</span>
          支持多种编程语言高亮，代码会实时渲染，直接输入即可看到效果。
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Syntax highlighting patterns
  const languages = {
    javascript: {
      keywords: /\b(const|let|var|function|return|if|else|for|while|class|import|export|from|async|await|new|this|try|catch|throw|typeof|instanceof|in|of)\b/g,
      strings: /(['"`])(?:(?!\1)[^\\]|\\.)*\1/g,
      comments: /\/\/.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_$][a-zA-Z0-9_$]*(?=\()/g,
    },
    typescript: {
      keywords: /\b(const|let|var|function|return|if|else|for|while|class|import|export|from|async|await|new|this|try|catch|throw|interface|type|extends|implements|readonly|private|public|protected)\b/g,
      strings: /(['"`])(?:(?!\1)[^\\]|\\.)*\1/g,
      comments: /\/\/.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_$][a-zA-Z0-9_$]*(?=\()/g,
    },
    python: {
      keywords: /\b(def|class|return|if|else|elif|for|while|import|from|as|try|except|raise|with|lambda|None|True|False|and|or|not|in|is)\b/g,
      strings: /(['"""'''"])(?:(?!\1)[^\\]|\\.)*\1/g,
      comments: /#.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_][a-zA-Z0-9_]*(?=\()/g,
    },
    java: {
      keywords: /\b(public|private|protected|class|interface|extends|implements|return|if|else|for|while|import|package|static|final|void|int|String|boolean|new|this|try|catch)\b/g,
      strings: /"(?:[^"\\]|\\.)*"/g,
      comments: /\/\/.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_$][a-zA-Z0-9_$]*(?=\()/g,
    },
    go: {
      keywords: /\b(package|import|func|return|if|else|for|range|var|const|type|struct|interface|map|chan|go|defer|make|new)\b/g,
      strings: /`(?:[^`])*`|"(?:[^"\\]|\\.)*"/g,
      comments: /\/\/.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_][a-zA-Z0-9_]*(?=\()/g,
    },
    rust: {
      keywords: /\b(fn|let|mut|const|return|if|else|for|while|match|impl|struct|enum|trait|use|mod|pub|crate|where|loop|async|await)\b/g,
      strings: /"(?:[^"\\]|\\.)*"|b"(?:[^"\\]|\\.)*"/g,
      comments: /\/\/.*$/gm,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b[a-zA-Z_][a-zA-Z0-9_]*(?=\()/g,
      macros: /\b[a-zA-Z_][a-zA-Z0-9_]*!/g,
    },
    css: {
      properties: /[\w-]+(?=\s*:)/g,
      selectors: /[.#][\w-]+/g,
      strings: /"(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'/g,
      comments: /\/\*[\s\S]*?\*\//g,
      numbers: /\b\d+(\.\d+)?(px|em|rem|%|vh|vw|s|ms|deg)?\b/g,
      keywords: /\b(color|background|font|margin|padding|border|display|position|width|height|flex|grid|none|auto|absolute|relative|fixed|center)\b/g,
    },
    html: {
      tags: /&lt;\/?[\w-]+/g,
      attrs: /\s[\w-]+(?==)/g,
      strings: /"(?:[^"\\]|\\.)*"/g,
      comments: /&lt;!--[\s\S]*?--&gt;/g,
    },
    json: {
      keys: /"(?:[^"\\]|\\.)*"(?=\s*:)/g,
      strings: /"(?:[^"\\]|\\.)*"/g,
      numbers: /\b\d+(\.\d+)?\b/g,
      booleans: /\b(true|false|null)\b/g,
    },
    sql: {
      keywords: /\b(SELECT|INSERT|UPDATE|DELETE|FROM|WHERE|JOIN|LEFT|RIGHT|INNER|OUTER|ON|GROUP|ORDER|BY|HAVING|LIMIT|OFFSET|AND|OR|NOT|NULL|AS|CREATE|TABLE|VALUES|INDEX|PRIMARY|KEY|FOREIGN|REFERENCES)\b/gi,
      strings: /'(?:[^'\\]|\\.)*'/g,
      numbers: /\b\d+(\.\d+)?\b/g,
      functions: /\b(COUNT|SUM|AVG|MIN|MAX|DISTINCT)\b/gi,
    },
    bash: {
      keywords: /\b(if|then|else|elif|fi|for|while|do|done|case|esac|function|return|exit|echo|export|source|cd|ls|pwd|cat|grep|awk|sed)\b/g,
      strings: /"(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*'/g,
      comments: /#.*$/gm,
      variables: /\$\w+|\$\{[^}]*\}/g,
    },
  };

  // One Dark Pro color scheme
  const themes = {
    onedark: {
      bg: '#282c34',
      headerBg: '#21252b',
      border: '#3e4451',
      text: '#abb2bf',
      keyword: '#c678dd',
      string: '#98c379',
      comment: '#5c6370',
      number: '#d19a66',
      function: '#61afef',
      variable: '#e06c75',
      tag: '#e06c75',
      attr: '#d19a66',
      filename: '#9da5b4',
    },
    dracula: {
      bg: '#282a36',
      headerBg: '#21222c',
      border: '#44475a',
      text: '#f8f8f2',
      keyword: '#ff79c6',
      string: '#f1fa8c',
      comment: '#6272a4',
      number: '#bd93f9',
      function: '#50fa7b',
      variable: '#f8f8f2',
      tag: '#ff79c6',
      attr: '#50fa7b',
      filename: '#6272a4',
    },
    github: {
      bg: '#ffffff',
      headerBg: '#f6f8fa',
      border: '#d1d5da',
      text: '#24292e',
      keyword: '#d73a49',
      string: '#032f62',
      comment: '#6a737d',
      number: '#005cc5',
      function: '#6f42c1',
      variable: '#e36209',
      tag: '#22863a',
      attr: '#6f42c1',
      filename: '#586069',
    },
  };

  // File extensions
  const fileExtensions = {
    javascript: 'js',
    typescript: 'ts',
    python: 'py',
    java: 'java',
    go: 'go',
    rust: 'rs',
    css: 'css',
    html: 'html',
    json: 'json',
    sql: 'sql',
    bash: 'sh',
  };

  // DOM elements
  const codeInput = document.getElementById('code-input');
  const highlightLayer = document.getElementById('highlight-layer');
  const filename = document.getElementById('filename');
  const editorContainer = document.getElementById('editor-container');
  const formatBtn = document.getElementById('format-btn');
  const canvas = document.createElement('canvas');
  const languageSelect = document.getElementById('language-select');
  const themeSelect = document.getElementById('theme-select');
  const downloadBtn = document.getElementById('download-btn');
  const sampleBtn = document.getElementById('sample-btn');

  // Sample code
  const samples = {
    javascript: `function fibonacci(n) {
  if (n <= 1) return n;
  return fibonacci(n - 1) + fibonacci(n - 2);
}

// Calculate first 10 numbers
for (let i = 0; i < 10; i++) {
  console.log(fibonacci(i));
}`,
    typescript: `interface User {
  id: number;
  name: string;
  email: string;
}

async function getUser(id: number): Promise<User> {
  const response = await fetch(\`/api/users/\${id}\`);
  return response.json();
}`,
    python: `def fibonacci(n):
    if n <= 1:
        return n
    return fibonacci(n-1) + fibonacci(n-2)

# Calculate first 10 numbers
for i in range(10):
    print(fibonacci(i))`,
    java: `public class Fibonacci {
    public static int fib(int n) {
        if (n <= 1) return n;
        return fib(n - 1) + fib(n - 2);
    }

    public static void main(String[] args) {
        for (int i = 0; i < 10; i++) {
            System.out.println(fib(i));
        }
    }
}`,
    go: `package main

${'import'} "fmt"

func fibonacci(n int) int {
    if n <= 1 {
        return n
    }
    return fibonacci(n-1) + fibonacci(n-2)
}

func main() {
    for i := 0; i < 10; i++ {
        fmt.Println(fibonacci(i))
    }
}`,
    rust: `fn fibonacci(n: u32) -> u32 {
    match n {
        0 | 1 => n,
        _ => fibonacci(n - 1) + fibonacci(n - 2),
    }
}

fn main() {
    for i in 0..10 {
        println!("{}", fibonacci(i));
    }
}`,
    css: `.container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.card {
  padding: 2rem;
  border-radius: 1rem;
  background: white;
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
}`,
    html: `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Hello World</title>
</head>
<body>
  <div class="container">
    <h1>Hello, World!</h1>
    <p>Welcome to my website.</p>
  </div>
</body>
</html>`,
    json: `{
  "name": "my-project",
  "version": "1.0.0",
  "description": "A sample project",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.0"
  }
}`,
    sql: `SELECT u.id, u.name, u.email, COUNT(o.id) as order_count
FROM users u
LEFT JOIN orders o ON u.id = o.user_id
WHERE u.created_at >= '2024-01-01'
GROUP BY u.id
ORDER BY order_count DESC
LIMIT 10;`,
    bash: `#!/bin/bash

# Backup script
BACKUP_DIR="/backup/$(date +%Y%m%d)"
SOURCE_DIR="/data"

echo "Starting backup..."
mkdir -p "$BACKUP_DIR"
tar -czf "$BACKUP_DIR/archive.tar.gz" "$SOURCE_DIR"
echo "Backup complete: $BACKUP_DIR"`,
  };

  function escapeHtml(text) {
    return text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function highlightCode(code, language, theme) {
    const lang = languages[language];
    if (!lang) {
      return `<span style="color:${theme.text}">${escapeHtml(code)}</span>`;
    }

    const lines = code.split('\n');
    let html = '';

    lines.forEach((line) => {
      let lineHtml = '';
      let pos = 0;

      const patterns = [
        { regex: lang.comments || null, color: theme.comment },
        { regex: lang.strings || null, color: theme.string },
        { regex: lang.keywords || null, color: theme.keyword },
        { regex: lang.numbers || null, color: theme.number },
        { regex: lang.functions || null, color: theme.function },
        { regex: lang.variables || null, color: theme.variable },
        { regex: lang.tags || null, color: theme.tag },
        { regex: lang.attrs || null, color: theme.attr },
        { regex: lang.selectors || null, color: theme.function },
        { regex: lang.properties || null, color: theme.keyword },
        { regex: lang.booleans || null, color: theme.keyword },
        { regex: lang.macros || null, color: theme.variable },
      ];

      while (pos < line.length) {
        let matched = false;

        for (const { regex, color } of patterns) {
          if (!regex) continue;
          regex.lastIndex = pos;
          const match = regex.exec(line);

          if (match && match.index === pos) {
            lineHtml += `<span style="color:${color}">${escapeHtml(match[0])}</span>`;
            pos += match[0].length;
            matched = true;
            break;
          }
        }

        if (!matched) {
          lineHtml += `<span style="color:${theme.text}">${escapeHtml(line[pos])}</span>`;
          pos++;
        }
      }

      html += lineHtml + '\n';
    });

    return html;
  }

  function applyTheme(theme) {
    if (editorContainer) {
      editorContainer.style.backgroundColor = theme.bg;
    }

    const header = editorContainer?.querySelector('div:first-child');
    if (header) {
      header.style.backgroundColor = theme.headerBg;
      header.style.borderColor = theme.border;
    }

    const codeArea = codeInput?.parentElement;
    if (codeArea) {
      codeArea.style.backgroundColor = theme.bg;
    }

    if (codeInput) {
      codeInput.style.caretColor = theme.text;
    }

    if (highlightLayer) {
      highlightLayer.style.color = theme.text;
    }

    if (filename) {
      filename.style.color = theme.filename;
    }
  }

  function render() {
    const code = codeInput?.value || '';
    const language = languageSelect?.value || 'javascript';
    const themeName = themeSelect?.value || 'onedark';
    const theme = themes[themeName];

    applyTheme(theme);

    if (highlightLayer) {
      highlightLayer.innerHTML = highlightCode(code, language, theme);
    }

    const ext = fileExtensions[language] || 'txt';
    if (filename) {
      filename.textContent = `main.${ext}`;
    }

    // 同步高度
    syncHeight();
  }

  function syncScroll() {
    if (highlightLayer && codeInput) {
      highlightLayer.scrollTop = codeInput.scrollTop;
      highlightLayer.scrollLeft = codeInput.scrollLeft;
    }
  }

  function syncHeight() {
    if (highlightLayer && codeInput) {
      // 同步高亮层高度与 textarea 一致
      highlightLayer.style.height = codeInput.offsetHeight + 'px';
    }
  }

  function autoResize() {
    if (!codeInput) return;
    // 重置高度以获取正确的 scrollHeight
    codeInput.style.height = 'auto';
    // 设置新高度（最小 320px）
    const newHeight = Math.max(320, codeInput.scrollHeight);
    codeInput.style.height = newHeight + 'px';
    // 同步高亮层高度
    syncHeight();
  }

  // Event listeners
  codeInput?.addEventListener('input', () => {
    autoResize();
    render();
  });
  codeInput?.addEventListener('scroll', syncScroll, { passive: true });
  languageSelect?.addEventListener('change', render);
  themeSelect?.addEventListener('change', render);

  // Format code using Prettier or sql-formatter
  async function formatCode(code, language) {
    if (!code.trim()) return code;

    // Handle SQL separately
    if (language === 'sql') {
      try {
        const { format } = await import('sql-formatter');
        return format(code, {
          language: 'sql',
          indent: '  ',
          keywordCase: 'upper',
          linesBetweenQueries: 1,
        });
      } catch (error) {
        console.error('SQL format error:', error);
        return code;
      }
    }

    // Supported languages for Prettier
    const supportedLangs = ['javascript', 'typescript', 'json', 'css', 'html'];

    if (!supportedLangs.includes(language)) {
      return code;
    }

    try {
      // Load Prettier from CDN if not loaded
      if (typeof window.prettier === 'undefined') {
        await loadScript('https://unpkg.com/prettier@3.1.1/standalone.js');
      }

      const prettier = window.prettier;
      let parser = 'babel';

      // Map language to parser
      switch (language) {
        case 'javascript':
          parser = 'babel';
          break;
        case 'typescript':
          parser = 'typescript';
          break;
        case 'json':
          parser = 'json';
          break;
        case 'css':
          parser = 'css';
          break;
        case 'html':
          parser = 'html';
          break;
      }

      return prettier.format(code, {
        parser: parser,
        tabWidth: 2,
        useTabs: false,
        semi: true,
        singleQuote: true,
        trailingComma: 'es5',
        printWidth: 80,
        bracketSpacing: true,
        arrowParens: 'avoid',
        endOfLine: 'lf',
      });
    } catch (error) {
      console.error('Prettier format error:', error);
      return code;
    }
  }

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = src;
      script.onload = resolve;
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  formatBtn?.addEventListener('click', async () => {
    const code = codeInput?.value || '';
    const language = languageSelect?.value || 'javascript';

    if (codeInput && code.trim()) {
      const formatted = await formatCode(code, language);
      codeInput.value = formatted;
      autoResize();
      render();
    }
  });

  sampleBtn?.addEventListener('click', () => {
    const lang = languageSelect?.value || 'javascript';
    if (codeInput) {
      codeInput.value = samples[lang] || '';
      autoResize();
      render();
    }
  });

  async function renderExportCanvas(): Promise<HTMLCanvasElement | null> {
    const code = codeInput?.value || '';
    const language = languageSelect?.value || 'javascript';
    const themeName = themeSelect?.value || 'onedark';
    const theme = themes[themeName];

    const ctx = canvas.getContext('2d');
    if (!ctx) return null;

    // Layout constants
    const padding = { x: 28, y: 24 };
    const fontSize = 14;
    const lineHeight = 22;
    const headerHeight = 46;
    const buttonRadius = 6;

    const lines = code.split('\n');
    const maxLineLength = Math.max(...lines.map(l => l.length), 30);

    // Calculate dimensions
    const contentWidth = Math.max(480, maxLineLength * 9 + padding.x * 2);
    const contentHeight = Math.max(200, lines.length * lineHeight + padding.y * 2);

    const width = contentWidth;
    const height = headerHeight + contentHeight;

    canvas.width = width * 2;
    canvas.height = height * 2;
    ctx.scale(2, 2);

    // Background
    ctx.fillStyle = theme.bg;
    ctx.fillRect(0, 0, width, height);

    // Header bar
    ctx.fillStyle = theme.headerBg;
    ctx.fillRect(0, 0, width, headerHeight);

    // Header border
    ctx.strokeStyle = theme.border;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, headerHeight);
    ctx.lineTo(width, headerHeight);
    ctx.stroke();

    // Window buttons
    const buttonY = headerHeight / 2;
    const buttonColors = ['#ff5f57', '#febc2e', '#28c840'];
    buttonColors.forEach((color, i) => {
      ctx.beginPath();
      ctx.arc(20 + i * 20, buttonY, buttonRadius, 0, Math.PI * 2);
      ctx.fillStyle = color;
      ctx.fill();
    });

    // File name centered
    ctx.fillStyle = theme.filename;
    ctx.font = '13px -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    const ext = fileExtensions[language] || 'txt';
    ctx.fillText(`main.${ext}`, width / 2, buttonY);

    // Font setup for code
    ctx.font = `${fontSize}px "SF Mono", Monaco, "Cascadia Code", "Fira Code", Consolas, monospace`;
    ctx.textAlign = 'left';
    ctx.textBaseline = 'alphabetic';

    const lang = languages[language];
    const codeX = padding.x;

    lines.forEach((line, i) => {
      const y = headerHeight + padding.y + i * lineHeight;
      if (y > height - padding.y) return;

      let x = codeX;
      let pos = 0;

      if (!lang) {
        ctx.fillStyle = theme.text;
        ctx.fillText(line, x, y + fontSize * 0.85);
        return;
      }

      const patterns = [
        { regex: lang.comments || null, color: theme.comment },
        { regex: lang.strings || null, color: theme.string },
        { regex: lang.keywords || null, color: theme.keyword },
        { regex: lang.numbers || null, color: theme.number },
        { regex: lang.functions || null, color: theme.function },
        { regex: lang.variables || null, color: theme.variable },
        { regex: lang.tags || null, color: theme.tag },
        { regex: lang.attrs || null, color: theme.attr },
        { regex: lang.selectors || null, color: theme.function },
        { regex: lang.properties || null, color: theme.keyword },
        { regex: lang.booleans || null, color: theme.keyword },
        { regex: lang.macros || null, color: theme.variable },
      ];

      while (pos < line.length) {
        let matched = false;

        for (const { regex, color } of patterns) {
          if (!regex) continue;
          regex.lastIndex = pos;
          const match = regex.exec(line);

          if (match && match.index === pos) {
            ctx.fillStyle = color;
            ctx.fillText(match[0], x, y + fontSize * 0.85);
            x += ctx.measureText(match[0]).width;
            pos += match[0].length;
            matched = true;
            break;
          }
        }

        if (!matched) {
          ctx.fillStyle = theme.text;
          ctx.fillText(line[pos], x, y + fontSize * 0.85);
          x += ctx.measureText(line[pos]).width;
          pos++;
        }
      }
    });

    return canvas;
  }

  downloadBtn?.addEventListener('click', async () => {
    const c = await renderExportCanvas();
    if (!c) return;
    const link = document.createElement('a');
    link.download = `code-${Date.now()}.png`;
    link.href = c.toDataURL('image/png');
    link.click();
  });

  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement | null;
  if (copyBtn) {
    const { bindCopyButton, canvasToPngBlob } = await import('../scripts/clipboard');
    bindCopyButton(copyBtn, () => ({
      blob: (async () => {
        const c = await renderExportCanvas();
        if (!c) throw new Error('渲染失败');
        return canvasToPngBlob(c);
      })(),
      mime: 'image/png',
    }));
  }

  // Initial render
  if (codeInput) {
    codeInput.value = samples.javascript;
  }
  autoResize();
  render();
</script>

